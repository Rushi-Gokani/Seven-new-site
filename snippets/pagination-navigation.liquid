{% doc %}
  Renders pagination navigation for paginated content.

  @param {paginate} paginate - The paginate object

  @example
  {% render 'pagination-navigation', paginate: paginate %}
{% enddoc %}

{%- if paginate.pages > 1 -%}
  <nav class="pagination flex items-center justify-center gap-0.5" role="navigation" aria-label="Pagination">
    {%- if paginate.previous -%}
      <a
        href="{{ paginate.previous.url }}"
        class="flex h-7 items-center gap-0.5 rounded px-2 text-xs font-medium text-gray-500 transition-colors hover:bg-gray-100 hover:text-gray-700"
        aria-label="Previous page"
      >
        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"></path>
        </svg>
      </a>
    {%- else -%}
      <span class="flex h-7 items-center gap-0.5 rounded px-2 text-xs font-medium text-gray-300">
        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"></path>
        </svg>
      </span>
    {%- endif -%}

    <div class="flex items-center gap-0.5">
      {%- for part in paginate.parts -%}
        {%- if part.is_link -%}
          <a
            href="{{ part.url }}"
            class="flex h-7 min-w-7 items-center justify-center rounded px-2 text-xs font-medium text-gray-500 transition-colors hover:bg-gray-100 hover:text-gray-700"
            aria-label="Page {{ part.title }}"
          >
            {{ part.title }}
          </a>
        {%- else -%}
          {%- if part.title == paginate.current_page -%}
            <span
              class="flex h-7 min-w-7 items-center justify-center rounded bg-gray-800 px-2 text-xs font-semibold text-white"
              aria-current="page"
            >
              {{ part.title }}
            </span>
          {%- else -%}
            <span class="flex h-7 min-w-7 items-center justify-center rounded px-2 text-xs font-medium text-gray-400">
              {{ part.title }}
            </span>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if paginate.next -%}
      <a
        href="{{ paginate.next.url }}"
        class="flex h-7 items-center gap-0.5 rounded px-2 text-xs font-medium text-gray-500 transition-colors hover:bg-gray-100 hover:text-gray-700"
        aria-label="Next page"
      >
        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>
    {%- else -%}
      <span class="flex h-7 items-center gap-0.5 rounded px-2 text-xs font-medium text-gray-300">
        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"></path>
        </svg>
      </span>
    {%- endif -%}
  </nav>

  <p class="mt-3 text-center text-xs text-gray-400">
    {{ paginate.current_offset | plus: 1 }}-{% if paginate.next %}{{ paginate.current_offset | plus: paginate.page_size }}{% else %}{{ paginate.items }}{% endif %} of {{ paginate.items }}
  </p>
{%- endif -%}
