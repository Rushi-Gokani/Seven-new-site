{% doc %}
  Renders a product card for grid display.

  @param {product} [product] - The product object to render
  @param {product} [prod] - Backward-compatible product alias
  @param {boolean} [show_vendor] - Show product vendor
  @param {boolean} [show_quick_add] - Show quick add to cart button
  @param {boolean} [quick_add_variant_selector] - Enable variant selector quick add flow
  @param {boolean} [show_secondary_image] - Show secondary image on hover
  @param {boolean} [show_sale_badge] - Show sale badge
  @param {boolean} [show_sold_out_badge] - Show sold out badge
  @param {boolean} [show_low_stock_badge] - Show low stock badge
  @param {number} [low_stock_threshold] - Low stock threshold
  @param {boolean} [show_variant_chips] - Show variant chips
  @param {boolean} [show_new_badge] - Show new badge
  @param {string} [image_ratio] - Card image ratio
  @param {string} [image_fit] - Card image fit mode
  @param {string} [loading] - Image loading strategy: 'lazy' (default) or 'eager'

  @example
  {% render 'product-grid-item', product: product %}
{% enddoc %}

{%- liquid
  assign card_product = product | default: prod

  assign show_vendor = show_vendor | default: settings.product_card_show_vendor, allow_false: true | default: false
  assign show_quick_add = show_quick_add | default: settings.product_card_show_quick_add, allow_false: true | default: true, allow_false: true
  assign show_secondary_image = show_secondary_image | default: settings.product_card_show_secondary_image, allow_false: true | default: true, allow_false: true
  assign show_sale_badge = show_sale_badge | default: settings.product_card_show_sale_badge, allow_false: true | default: true, allow_false: true
  assign show_sold_out_badge = show_sold_out_badge | default: settings.product_card_show_sold_out_badge, allow_false: true | default: true, allow_false: true
  assign show_low_stock_badge = show_low_stock_badge | default: settings.product_card_show_low_stock_badge, allow_false: true | default: true, allow_false: true
  assign low_stock_threshold = low_stock_threshold | default: settings.product_card_low_stock_threshold | default: 5
  assign show_variant_chips = show_variant_chips | default: settings.product_card_show_variant_chips, allow_false: true | default: true, allow_false: true
  assign show_new_badge = show_new_badge | default: settings.product_card_show_new_badge, allow_false: true | default: true, allow_false: true
  assign image_ratio = image_ratio | default: settings.product_card_image_ratio | default: 'portrait'
  assign image_fit = image_fit | default: settings.product_card_image_fit | default: 'cover'
  assign loading = loading | default: 'lazy'
  assign quick_add_variant_selector = quick_add_variant_selector | default: false

  assign media_aspect_ratio = '3 / 4'
  case image_ratio
    when 'adapt'
      if card_product.featured_image != blank
        if card_product.featured_image.aspect_ratio
          assign media_aspect_ratio = card_product.featured_image.aspect_ratio
        else
          assign media_aspect_ratio = 1
        endif
      else
        assign media_aspect_ratio = 1
      endif
    when 'square'
      assign media_aspect_ratio = '1 / 1'
    else
      assign media_aspect_ratio = '3 / 4'
  endcase

  assign image_fit_class = 'object-cover'
  if image_fit == 'contain'
    assign image_fit_class = 'object-contain'
  endif

  assign first_variant = card_product.selected_or_first_available_variant
  assign has_sale = false
  if card_product.compare_at_price > card_product.price
    assign has_sale = true
    assign sale_percent = card_product.compare_at_price | minus: card_product.price | times: 100.0 | divided_by: card_product.compare_at_price | round
  endif
-%}

{%- if card_product != blank -%}
  <article class="product-card group relative flex flex-col">
    <div class="product-card__media relative overflow-hidden rounded-xl bg-gray-100">
      <a href="{{ card_product.url }}" class="block" style="aspect-ratio: {{ media_aspect_ratio }};" aria-label="{{ card_product.title | escape }}">
        {%- if card_product.featured_image -%}
          <img
            src="{{ card_product.featured_image | image_url: width: 600 }}"
            srcset="{{ card_product.featured_image | image_url: width: 300 }} 300w,
                    {{ card_product.featured_image | image_url: width: 450 }} 450w,
                    {{ card_product.featured_image | image_url: width: 600 }} 600w,
                    {{ card_product.featured_image | image_url: width: 900 }} 900w"
            sizes="(max-width: 768px) 50vw, 25vw"
            alt="{{ card_product.featured_image.alt | default: card_product.title | escape }}"
            class="h-full w-full {{ image_fit_class }} transition-transform duration-500 ease-out group-hover:scale-105"
            loading="{{ loading }}"
            decoding="async"
            width="{{ card_product.featured_image.width }}"
            height="{{ card_product.featured_image.height }}"
          >

          {%- if show_secondary_image and card_product.images.size > 1 -%}
            <img
              src="{{ card_product.images[1] | image_url: width: 600 }}"
              srcset="{{ card_product.images[1] | image_url: width: 300 }} 300w,
                      {{ card_product.images[1] | image_url: width: 450 }} 450w,
                      {{ card_product.images[1] | image_url: width: 600 }} 600w"
              sizes="(max-width: 768px) 50vw, 25vw"
              alt="{{ card_product.images[1].alt | default: card_product.title | escape }}"
              class="absolute inset-0 h-full w-full {{ image_fit_class }} opacity-0 transition-opacity duration-500 group-hover:opacity-100"
              loading="lazy"
              decoding="async"
              width="{{ card_product.images[1].width }}"
              height="{{ card_product.images[1].height }}"
            >
          {%- endif -%}
        {%- else -%}
          <div class="flex h-full w-full items-center justify-center bg-gray-100">
            <svg class="h-16 w-16 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
          </div>
        {%- endif -%}
      </a>

      {%- if show_sold_out_badge and card_product.available == false -%}
        <span class="pointer-events-none absolute left-3 top-3 rounded-full bg-gray-800 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-white">
          Sold out
        </span>
      {%- elsif show_sale_badge and has_sale -%}
        <span class="pointer-events-none absolute left-3 top-3 rounded-full bg-red-500 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-white">
          -{{ sale_percent }}%
        </span>
      {%- endif -%}

      {%- if show_low_stock_badge -%}
        {%- if card_product.available and first_variant.inventory_quantity > 0 and first_variant.inventory_quantity <= low_stock_threshold -%}
          <span class="pointer-events-none absolute right-3 top-3 rounded-full bg-amber-500 px-2.5 py-1 text-xs font-semibold text-white">
            Only {{ first_variant.inventory_quantity }} left
          </span>
        {%- endif -%}
      {%- endif -%}

      {%- if show_quick_add and card_product.available -%}
        {%- if card_product.has_only_default_variant or quick_add_variant_selector == false -%}
          <div class="quick-add pointer-events-auto absolute right-2 bottom-2 transition-all duration-300 md:pointer-events-none md:translate-y-2 md:opacity-0 md:group-hover:pointer-events-auto md:group-hover:translate-y-0 md:group-hover:opacity-100">
            <ajax-cart-product-form>
              {%- form 'product', card_product, class: 'quick-add-form' -%}
                <input type="hidden" name="id" value="{{ first_variant.id }}">
                <input type="hidden" name="quantity" value="1">
                <button
                  type="submit"
                  class="quick-add-btn group/btn flex h-8 w-8 items-center justify-center rounded-full bg-gray-900 text-white shadow-md transition-all duration-200 hover:bg-cloud-burst active:scale-95"
                  aria-label="Add to cart"
                >
                  <svg class="h-4 w-4 group-[.is-loading]/btn:hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14m-7-7h14"></path>
                  </svg>
                  <svg class="hidden h-4 w-4 animate-spin group-[.is-loading]/btn:block" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                  </svg>
                  <span class="sr-only">Add to cart</span>
                </button>
              {%- endform -%}
            </ajax-cart-product-form>
          </div>
        {%- else -%}
          <div
            class="quick-add pointer-events-auto absolute right-2 bottom-2 transition-all duration-300 md:pointer-events-none md:translate-y-2 md:opacity-0 md:group-hover:pointer-events-auto md:group-hover:translate-y-0 md:group-hover:opacity-100"
            x-data="productCardQuickAdd({ initialVariantId: {{ first_variant.id | json }} })"
            :class="isOpen && 'md:pointer-events-auto md:translate-y-0 md:opacity-100'"
            @keydown.escape.prevent.stop="closeOptions()"
          >
            <script type="application/json" x-ref="quickAddVariants">
              [
                {%- for variant in card_product.variants -%}
                  {
                    "id": {{ variant.id | json }},
                    "available": {{ variant.available | json }},
                    "options": {{ variant.options | json }}
                  }{% unless forloop.last %},{% endunless %}
                {%- endfor -%}
              ]
            </script>

            <ajax-cart-product-form>
              {%- form 'product', card_product, class: 'quick-add-form' -%}
                <input type="hidden" name="id" value="{{ first_variant.id }}" :value="selectedVariantId">
                <input type="hidden" name="quantity" value="1">

                <div class="relative" @click.outside="closeOptions()">
                  <button
                    type="button"
                    class="flex h-8 w-8 items-center justify-center rounded-full bg-gray-900 text-white shadow-md transition-all duration-200 hover:bg-cloud-burst active:scale-95"
                    @click="toggleOptions()"
                    :aria-expanded="isOpen.toString()"
                    :aria-label="isOpen ? 'Close options' : 'Choose options'"
                  >
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14m-7-7h14"></path>
                    </svg>
                    <span class="sr-only" x-text="isOpen ? 'Close options' : 'Choose options'"></span>
                  </button>

                  <div
                    x-show="isOpen"
                    x-transition:enter="transition ease-out duration-150"
                    x-transition:enter-start="opacity-0 -translate-y-1"
                    x-transition:enter-end="opacity-100 translate-y-0"
                    x-transition:leave="transition ease-in duration-100"
                    x-transition:leave-start="opacity-100 translate-y-0"
                    x-transition:leave-end="opacity-0 -translate-y-1"
                    x-cloak
                    class="absolute right-0 bottom-full z-20 mb-2 w-52 space-y-2 rounded-lg border border-gray-200 bg-white p-2 shadow-lg [[x-cloak]]:hidden"
                  >
                    {%- for option in card_product.options_with_values -%}
                      {%- assign option_index = forloop.index0 -%}
                      <label class="block text-left">
                        <span class="mb-1 block text-xs font-medium text-gray-600">{{ option.name }}</span>
                        <select
                          data-product-card-option
                          class="w-full rounded-md border border-gray-300 bg-white px-2.5 py-2 text-sm text-gray-800 focus:border-cloud-burst focus:outline-none focus:ring-1 focus:ring-cloud-burst"
                          @change="onOptionChange({{ option_index }}, $event.target.value)"
                        >
                          {%- for value in option.values -%}
                            <option value="{{ value | escape }}" {% if first_variant.options[option_index] == value %}selected{% endif %}>
                              {{ value }}
                            </option>
                          {%- endfor -%}
                        </select>
                      </label>
                    {%- endfor -%}

                    <button
                      type="submit"
                      class="quick-add-btn group/btn flex h-9 w-full items-center justify-center rounded-md bg-gray-900 px-3 text-xs font-semibold text-white transition-colors hover:bg-cloud-burst disabled:cursor-not-allowed disabled:bg-gray-300 disabled:text-gray-600"
                      :disabled="isAddDisabled"
                    >
                      <span class="group-[.is-loading]/btn:hidden" x-text="addButtonLabel"></span>
                      <svg class="hidden h-4 w-4 animate-spin group-[.is-loading]/btn:block" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                      </svg>
                    </button>

                    <div data-ajax-cart-messages="form" class="text-xs text-gray-700"></div>
                  </div>
                </div>
              {%- endform -%}
            </ajax-cart-product-form>
          </div>
        {%- endif -%}
      {%- endif -%}
    </div>

    <div class="product-card__info mt-4 flex flex-grow flex-col">
      {%- if show_vendor -%}
        <p class="text-xs uppercase tracking-wide text-gray-500">{{ card_product.vendor }}</p>
      {%- endif -%}

      <h3 class="mt-1 flex-grow">
        <a href="{{ card_product.url }}" class="text-base font-medium text-gray-900 transition-colors hover:text-cloud-burst-500 line-clamp-2">
          {{ card_product.title }}
        </a>
      </h3>

      <div class="mt-2 flex items-center gap-2">
        <span class="text-base font-semibold{% if has_sale %} text-red-600{% endif %}">
          {{ card_product.price | money }}
        </span>

        {%- if has_sale -%}
          <span class="text-sm text-gray-400 line-through">
            {{ card_product.compare_at_price | money }}
          </span>
        {%- endif -%}

        {%- if card_product.price_varies -%}
          <span class="text-xs text-gray-500">(from {{ card_product.price_min | money }})</span>
        {%- endif -%}
      </div>

      {%- if show_variant_chips and card_product.options.size == 1 and card_product.options.first != 'Title' -%}
        <div class="mt-2 flex flex-wrap gap-1">
          {%- for variant in card_product.variants limit: 4 -%}
            {%- if variant.option1 contains '#' -%}
              {%- assign color = variant.option1 | split: '#' | last -%}
              <span
                class="h-5 w-5 rounded-full border border-gray-200"
                style="background-color: {{ color }}"
                title="{{ variant.option1 | split: '#' | first }}"
              ></span>
            {%- else -%}
              <span class="rounded bg-gray-100 px-2 py-0.5 text-xs text-gray-600">{{ variant.option1 }}</span>
            {%- endif -%}
          {%- endfor -%}
          {%- if card_product.variants.size > 4 -%}
            <span class="text-xs text-gray-500">+{{ card_product.variants.size | minus: 4 }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if show_new_badge and card_product.tags contains 'new' -%}
        <span class="mt-2 inline-flex items-center gap-1 text-xs font-semibold text-cloud-burst-500">
          <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
          </svg>
          New arrival
        </span>
      {%- endif -%}
    </div>
  </article>
{%- endif -%}
