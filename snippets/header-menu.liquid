{% doc %}
  Renders the desktop header navigation.

  @param {linklist} [menu] - The navigation menu to render.
{% enddoc %}

{% if menu != blank and menu.links.size > 0 %}
<ul class="header-menu flex items-center justify-start gap-6 whitespace-nowrap">
  {% for link in menu.links %}
    <li>
      <a href="{{ link.url }}" class="uppercase hover:opacity-70 transition-opacity text-black no-underline">
        {{ link.title | escape }}
      </a>
    </li>
  {% endfor %}
</ul>
{% endif %}
