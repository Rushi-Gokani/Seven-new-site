{% schema %}
{
  "name": "Premium Product Page",
  "tag": "section",
  "class": "section-main-product-custom",
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "title",
      "name": "Title",
      "limit": 1
    },
    {
      "type": "price",
      "name": "Price",
      "limit": 1
    },
    {
      "type": "description",
      "name": "Description",
      "limit": 1
    },
    {
      "type": "rating",
      "name": "Rating",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "star_rating",
          "label": "Star Rating",
          "default": "4.9"
        },
        {
          "type": "text",
          "id": "review_count",
          "label": "Review Count",
          "default": "3,540 reviews"
        }
      ]
    },
    {
      "type": "refill_link",
      "name": "Refill Link",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Link Text",
          "default": "Save $9 with the Body Wash Refill Set"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    },
    {
      "type": "variant_picker",
      "name": "Variant Picker",
      "limit": 1
    },
    {
      "type": "buy_buttons",
      "name": "Buy Buttons",
      "limit": 1
    },
    {
      "type": "promo_bar",
      "name": "Promo Bar",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Promo Text",
          "default": "Get a free Mini Santal Deodorant on orders $70+"
        }
      ]
    },
    {
      "type": "cross_sell",
      "name": "Complete Your Routine",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "COMPLETE YOUR ROUTINE"
        },
        {
          "type": "product_list",
          "id": "products",
          "label": "Products"
        }
      ]
    },
    {
      "type": "size_info",
      "name": "Size Info",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "size_text",
          "label": "Size Text",
          "default": "15.2 FL OZ / 450 ML"
        }
      ]
    },
    {
      "type": "accordion",
      "name": "Accordion",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Badge Settings"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "BEST SELLER"
    },
    {
      "type": "header",
      "content": "Floating Badge"
    },
    {
      "type": "text",
      "id": "floating_badge_text",
      "label": "Floating Badge Text",
      "default": "GET 10% OFF"
    }
  ],
  "presets": [
    {
      "name": "Premium Product Page",
      "blocks": [
        { "type": "title" },
        { "type": "description" },
        { "type": "refill_link" },
        { "type": "size_info" },
        { "type": "rating" },
        { "type": "variant_picker" },
        { "type": "promo_bar" },
        { "type": "buy_buttons" },
        { "type": "cross_sell" },
        { "type": "accordion" },
        { "type": "accordion" }
      ]
    }
  ]
}
{% endschema %}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign image_media = product.media | where: "media_type", "image"
  assign image_count = image_media.size
-%}

<div 
  class="product-v2-container shopify-section-main-product-inner max-w-[1400px] mx-auto px-4 md:px-10 py-10"
  data-handle="{{ product.handle }}"
  data-id="{{ product.id }}"
  data-url="{{ product.url }}"
  data-section="{{ section.id }}"
  data-prodify="radio"
  x-data="{
    activeIndex: 0,
    totalImages: {{ image_count }},
    floatingClosed: false,
    goTo(index) {
      if (index < 0) index = this.totalImages - 1;
      if (index >= this.totalImages) index = 0;
      this.activeIndex = index;
      const scrollAmount = this.$refs.mainGallery.offsetWidth * index;
      this.$refs.mainGallery.scrollTo({
        left: scrollAmount,
        behavior: 'smooth'
      });
    }
  }"
>
  <script type="application/json" data-prodify-variants-json>
    {{ product.variants | json }}
  </script>
  <div class="grid grid-cols-1 md:grid-cols-[100px_1fr_1fr] lg:grid-cols-[110px_1fr_45%] gap-8 lg:gap-14">
    
    <!-- Desktop Vertical Thumbnails -->
    <div class="hidden md:flex flex-col gap-3 max-h-[600px] overflow-y-auto pr-2 custom-scrollbar">
      {% for media in image_media %}
        <button 
          @click="goTo({{ forloop.index0 }})"
          class="aspect-[4/5] w-full border-2 rounded-lg transition-all duration-200 overflow-hidden"
          :class="activeIndex === {{ forloop.index0 }} ? 'border-black' : 'border-transparent hover:opacity-80'"
        >
          {{ media | image_url: width: 150 | image_tag: class: 'w-full h-full object-cover', loading: 'lazy' }}
        </button>
      {% endfor %}
    </div>

    <!-- Main Image Gallery -->
    <div class="relative group">
      <!-- Badge Overlay -->
      <div class="absolute top-4 left-4 z-10 bg-white px-3 py-1 text-[10px] font-bold tracking-widest rounded-sm shadow-sm">
        {{ section.settings.badge_text | upcase }}
      </div>

      <div 
        x-ref="mainGallery"
        class="flex overflow-x-auto snap-x snap-mandatory hide-scrollbar rounded-xl bg-gray-50 aspect-[4/5]"
        @scroll.debounce.100ms="activeIndex = Math.round($event.target.scrollLeft / $event.target.offsetWidth)"
      >
        {% for media in image_media %}
          <div class="min-w-full snap-center flex items-center justify-center">
            {{ media | image_url: width: 1200 | image_tag: class: 'w-full h-full object-contain', loading: 'eager' }}
          </div>
        {% endfor %}
      </div>

      <!-- Mobile Pagination Dots -->
      <div class="flex justify-center gap-1.5 mt-4 md:hidden">
        {% for i in (1..image_count) %}
          <div 
            class="w-1.5 h-1.5 rounded-full transition-colors"
            :class="activeIndex === {{ forloop.index0 }} ? 'bg-black' : 'bg-gray-300'"
          ></div>
        {% endfor %}
      </div>
    </div>

    <!-- Product Info Side -->
    <div class="product-info flex flex-col gap-6">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'title' %}
            <div {{ block.shopify_attributes }}>
              <p class="text-[10px] font-bold tracking-[0.2em] text-gray-400 mb-1">{{ product.type | upcase }}</p>
              <h1 class="text-3xl lg:text-4xl font-semibold tracking-tight leading-tight uppercase">{{ product.title }}</h1>
            </div>

          {% when 'rating' %}
            <div class="flex items-center gap-2" {{ block.shopify_attributes }}>
              <div class="flex text-black">
                {% for i in (1..5) %}
                  <svg class="w-3 h-3 fill-current" viewBox="0 0 20 20"><path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/></svg>
                {% endfor %}
              </div>
              <span class="text-xs text-gray-500">{{ block.settings.star_rating }} ({{ block.settings.review_count }})</span>
            </div>

          {% when 'price' %}
            <div class="flex items-baseline gap-4" {{ block.shopify_attributes }}>
               <span class="text-xl font-bold">{{ current_variant.price | money }}</span>
               {% if current_variant.compare_at_price > current_variant.price %}
                 <span class="text-gray-400 line-through text-sm">{{ current_variant.compare_at_price | money }}</span>
               {% endif %}
               <span class="text-[10px] font-bold text-gray-500 tracking-widest uppercase ml-auto">
                 {{ current_variant.option1 }} / {{ current_variant.option2 }}
               </span>
            </div>

          {% when 'description' %}
            <div class="prose prose-sm text-gray-600 leading-relaxed font-light" {{ block.shopify_attributes }}>
              {{ product.description }}
            </div>

          {% when 'size_info' %}
            <div class="text-[11px] font-bold text-gray-500 tracking-widest uppercase" {{ block.shopify_attributes }}>
              {{ block.settings.size_text }}
            </div>

          {% when 'refill_link' %}
            <div {{ block.shopify_attributes }}>
              <a href="{{ block.settings.link_url | default: '#' }}" class="underline text-xs font-semibold hover:text-black transition-colors">
                {{ block.settings.text }}
              </a>
            </div>

        {% when 'variant_picker' %}
          <div class="flex flex-col gap-3" {{ block.shopify_attributes }}>
            <p class="text-[10px] font-bold tracking-[0.2em] text-gray-400 uppercase">
              SCENT: <span class="text-black" id="variant-title-{{ section.id }}">{{ current_variant.title | upcase }}</span>
            </p>
            <div class="flex gap-2.5 overflow-x-auto pb-2 hide-scrollbar" data-prodify-option-container>
              {% for variant in product.variants %}
                <div class="relative flex-shrink-0 w-[70px] h-[70px]">
                  <input 
                    type="radio" 
                    id="Variant-{{ variant.id }}" 
                    name="id" 
                    value="{{ variant.id }}"
                    class="peer absolute inset-0 opacity-0 cursor-pointer z-10"
                    {% if variant.id == current_variant.id %}checked{% endif %}
                    data-variant-title="{{ variant.title | upcase }}"
                  >
                  <label 
                    for="Variant-{{ variant.id }}"
                    class="block w-full h-full rounded-[10px] border border-transparent transition-all duration-200 overflow-hidden bg-[#F5F5F5] peer-checked:border-black peer-checked:shadow-sm pointer-events-none"
                  >
                    {% if variant.featured_image %}
                      {{ variant.featured_image | image_url: width: 200 | image_tag: class: 'w-full h-full object-contain p-2', loading: 'lazy' }}
                    {% else %}
                      <div class="w-full h-full flex items-center justify-center text-[10px] text-gray-400 font-medium">
                        {{ variant.title | upcase }}
                      </div>
                    {% endif %}
                  </label>
                </div>
              {% endfor %}
            </div>
          </div>

          {% when 'promo_bar' %}
            <div class="bg-gray-100 py-3 px-4 rounded-md text-center text-[10px] font-semibold tracking-wide" {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </div>

        {% when 'buy_buttons' %}
          <div class="flex flex-col gap-3" {{ block.shopify_attributes }}>
            <ajax-cart-product-form>
              {%- form 'product', product, id: 'product-form-v2', class: 'product-form', novalidate: 'novalidate', data-prodify-product-form: '' -%}
                <input type="hidden" name="id" value="{{ current_variant.id }}">
                <button 
                  type="submit" 
                  name="add"
                  class="w-full bg-black text-white py-5 rounded-full font-bold text-xs tracking-widest uppercase hover:opacity-90 transition-opacity disabled:bg-gray-200 disabled:text-gray-400"
                  {% unless current_variant.available %}disabled{% endunless %}
                >
                  <span class="in-[[processing]]:hidden">
                    {% if current_variant.available %}
                      {% if current_variant.inventory_policy == 'continue' and current_variant.inventory_quantity <= 0 %}
                        JOIN WAITLIST
                      {% else %}
                        ADD TO CART
                      {% endif %}
                    {% else %}
                      SOLD OUT
                    {% endif %}
                  </span>
                  <span class="hidden in-[[processing]]:block italic">ADDING...</span>
                </button>
              {%- endform -%}
            </ajax-cart-product-form>
            <div data-ajax-cart-errors="form" class="text-red-500 text-[10px] text-center mt-1"></div>
            <p class="text-[10px] text-center text-gray-500 italic mt-2">
              or 4 interest-free payments of $9.00 with <span class="font-bold underline text-black cursor-pointer">Afterpay ⓘ</span>
            </p>
          </div>

          {% when 'cross_sell' %}
            <div class="mt-8 pt-8 border-t border-gray-100" {{ block.shopify_attributes }}>
              <h3 class="text-[11px] font-bold tracking-[0.2em] mb-6 uppercase">{{ block.settings.heading }}</h3>
              <div class="flex flex-col gap-5">
                {% for item in block.settings.products %}
                  <a href="{{ item.url }}" class="flex gap-4 items-center group">
                    <div class="w-18 h-18 bg-gray-50 rounded-xl overflow-hidden flex-shrink-0 group-hover:opacity-80 transition-opacity">
                      {{ item.featured_image | image_url: width: 200 | image_tag: class: 'w-full h-full object-contain p-2' }}
                    </div>
                    <div class="flex flex-col">
                      <h4 class="text-[11px] font-bold tracking-wider uppercase leading-tight group-hover:underline underline-offset-4">{{ item.title }}</h4>
                      <p class="text-[10px] text-gray-400 mt-1 uppercase font-semibold">
                        {% if item.available %}
                          {{ item.price | money }}
                        {% else %}
                          SOLD OUT
                        {% endif %}
                      </p>
                    </div>
                    <div class="ml-auto opacity-0 group-hover:opacity-100 transition-opacity">
                       <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
                    </div>
                  </a>
                {% endfor %}
              </div>
            </div>

          {% when 'accordion' %}
            <div 
              class="border-t border-gray-100 py-5" 
              x-data="{ open: false }" 
              {{ block.shopify_attributes }}
            >
              <button 
                @click="open = !open" 
                class="flex justify-between items-center w-full text-left"
              >
                <span class="text-[11px] font-bold tracking-widest uppercase">{{ block.settings.heading }}</span>
                <span class="text-lg transition-transform duration-200" :class="open ? 'rotate-45' : ''">+</span>
              </button>
              <div 
                x-show="open" 
                x-collapse 
                class="mt-4 text-xs font-light leading-relaxed text-gray-500"
              >
                {{ block.settings.content }}
              </div>
            </div>

        {% endcase %}
      {% endfor %}
    </div>
  </div>

  <!-- Floating Badge -->
  <div 
    x-show="!floatingClosed"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="translate-y-10 opacity-0"
    x-transition:enter-end="translate-y-0 opacity-100"
    class="fixed bottom-6 left-6 z-[100] flex items-center bg-black text-white px-6 py-3.5 rounded-full shadow-2xl group transition-all hover:scale-105"
  >
    <span class="text-[10px] font-bold tracking-[0.2em]">{{ section.settings.floating_badge_text }}</span>
    <button 
      @click="floatingClosed = true"
      class="ml-6 opacity-40 hover:opacity-100 transition-opacity"
    >
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
  </div>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

  :root {
    --font-heading: 'Inter', sans-serif;
    --font-body: 'Inter', sans-serif;
  }

  .section-main-product-custom {
    font-family: var(--font-body);
    -webkit-font-smoothing: antialiased;
  }

  .section-main-product-custom h1, 
  .section-main-product-custom h2, 
  .section-main-product-custom h3, 
  .section-main-product-custom h4 {
    font-family: var(--font-heading);
  }

  .custom-scrollbar::-webkit-scrollbar {
    width: 3px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: #e5e7eb;
    border-radius: 10px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: #d1d5db;
  }
  
  .hide-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }

  /* Variant Picker Styles */
  [data-prodify-option-container] {
    -webkit-overflow-scrolling: touch;
  }
  
  [data-prodify-option-container] label {
    position: relative;
  }
  
  [data-prodify-option-container] label::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    opacity: 0;
    transition: opacity 0.2s ease;
    box-shadow: inset 0 0 0 1px rgba(0,0,0,0.05);
  }
  
  [data-prodify-option-container] input:not(:checked) + label:hover::after {
    opacity: 1;
  }

  /* Aspect Ratio Fallbacks */
  .aspect-\[4\/5\] {
    aspect-ratio: 4 / 5;
  }

  /* Alpine Collapse Hidden State */
  [x-cloak] { 
    display: none !important; 
  }

  /* Button Pulse Animation for Floating Badge */
  @keyframes subtle-pulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.02); }
    100% { transform: scale(1); }
  }
  .floating-badge {
    animation: subtle-pulse 3s infinite ease-in-out;
  }
</style>
