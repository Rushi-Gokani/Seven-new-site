{% liquid
  assign primary_links = blank

  if section.settings.primary_menu != blank
    assign primary_links = section.settings.primary_menu.links
  elsif linklists.footer.links != blank
    assign primary_links = linklists.footer.links
  endif
%}

<div class="w-full bg-gray-100">
  <div class="max-w-[1600px] mx-auto px-6 py-12 md:px-8 md:py-16">
    <!-- Top Section -->
    <div class="flex flex-col lg:flex-row gap-12 lg:gap-8">
      <!-- Left: Newsletter Signup -->
      <div class="lg:w-1/2 lg:pr-12">
        {% if section.settings.show_newsletter %}
          {% form 'customer', id: 'FooterNewsletter' %}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <h3 class="text-2xl font-medium text-black mb-4">{{ section.settings.newsletter_heading }}</h3>
            <div class="flex gap-3 max-w-md">
              <label class="sr-only" for="FooterNewsletter-email">Email address</label>
              <input
                id="FooterNewsletter-email"
                type="email"
                name="contact[email]"
                value="{% if customer %}{{ customer.email }}{% endif %}"
                autocomplete="email"
                required
                placeholder="Enter email address"
                class="flex-1 h-12 px-4 border border-gray-300 bg-white text-sm text-gray-900 placeholder:text-gray-400 focus-visible:outline-none focus-visible:border-black"
              >
              <button
                type="submit"
                class="h-12 px-8 bg-black text-white text-sm font-medium rounded-full hover:bg-gray-800 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-black focus-visible:ring-offset-2"
                name="commit"
              >
                Sign up
              </button>
            </div>
            {% if form.errors %}
              <div class="mt-3 text-sm text-rose-600">
                {{ form.errors | default_errors }}
              </div>
            {% elsif form.posted_successfully? %}
              <p class="mt-3 text-sm text-green-700">Thanks for subscribing.</p>
            {% endif %}
          {% endform %}
        {% endif %}
      </div>

      <!-- Right: 3 Columns -->
      <div class="lg:w-1/2">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
          <!-- Column 1 -->
          <div>
            <ul class="space-y-3">
              {% if section.settings.subscribe_url != blank %}
                <li><a href="{{ section.settings.subscribe_url }}" class="text-sm text-gray-700 hover:text-black transition-colors">Subscribe</a></li>
              {% endif %}
              {% if section.settings.member_url != blank %}
                <li><a href="{{ section.settings.member_url }}" class="text-sm text-gray-700 hover:text-black transition-colors">Become a Member</a></li>
              {% endif %}
              {% if section.settings.refer_url != blank %}
                <li><a href="{{ section.settings.refer_url }}" class="text-sm text-gray-700 hover:text-black transition-colors">Refer a Friend</a></li>
              {% endif %}
              {% if section.settings.quiz_url != blank %}
                <li><a href="{{ section.settings.quiz_url }}" class="text-sm text-gray-700 hover:text-black transition-colors">Take the Scent Quiz</a></li>
              {% endif %}
              {% if section.settings.store_url != blank %}
                <li><a href="{{ section.settings.store_url }}" class="text-sm text-gray-700 hover:text-black transition-colors">Find a Store</a></li>
              {% endif %}
            </ul>
          </div>

          <!-- Column 2 -->
          <div>
            <ul class="space-y-3">
              {% if section.settings.help_url != blank %}
                <li><a href="{{ section.settings.help_url }}" class="text-sm text-gray-700 hover:text-black transition-colors">Help Center</a></li>
              {% endif %}
              {% if section.settings.faq_url != blank %}
                <li><a href="{{ section.settings.faq_url }}" class="text-sm text-gray-700 hover:text-black transition-colors">FAQs</a></li>
              {% endif %}
              {% if shop.refund_policy != blank %}
                <li><a href="{{ shop.refund_policy.url }}" class="text-sm text-gray-700 hover:text-black transition-colors">Returns</a></li>
              {% endif %}
              {% if section.settings.contact_url != blank %}
                <li><a href="{{ section.settings.contact_url }}" class="text-sm text-gray-700 hover:text-black transition-colors">Contact</a></li>
              {% endif %}
            </ul>
          </div>

          <!-- Column 3 -->
          <div>
            <ul class="space-y-3">
              <li class="text-sm text-gray-700">Shipping: India</li>
              <li class="text-sm text-gray-700">Language: English</li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Section -->
    <div class="mt-12 pt-8 border-t border-gray-200">
      <div class="flex flex-col md:flex-row justify-between items-center gap-6">
        <!-- Left: Policy Links -->
        <div class="flex flex-wrap items-center gap-6">
          {% if shop.privacy_policy != blank %}
            <a href="{{ shop.privacy_policy.url }}" class="text-sm text-gray-600 hover:text-black transition-colors">Privacy Policy</a>
          {% endif %}
          {% if shop.terms_of_service != blank %}
            <a href="{{ shop.terms_of_service.url }}" class="text-sm text-gray-600 hover:text-black transition-colors">Terms & Conditions</a>
          {% endif %}
          {% if section.settings.accessibility_url != blank %}
            <a href="{{ section.settings.accessibility_url }}" class="text-sm text-gray-600 hover:text-black transition-colors">Accessibility</a>
          {% endif %}
          <button class="text-sm text-gray-600 hover:text-black transition-colors flex items-center gap-1" aria-label="Your Privacy Choices">
            Your Privacy Choices
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path>
            </svg>
          </button>
        </div>

        <!-- Right: Social Icons -->
        <div class="flex items-center gap-4">
          {% if section.settings.tiktok_url != blank %}
            <a href="{{ section.settings.tiktok_url }}" class="text-gray-600 hover:text-black transition-colors" aria-label="TikTok">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/>
              </svg>
            </a>
          {% endif %}
          {% if section.settings.instagram_url != blank %}
            <a href="{{ section.settings.instagram_url }}" class="text-gray-600 hover:text-black transition-colors" aria-label="Instagram">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "Footer",
    "class": "footer",
    "tag": "footer",
    "settings": [
      {
        "type": "header",
        "content": "Newsletter"
      },
      {
        "type": "checkbox",
        "id": "show_newsletter",
        "label": "Show newsletter signup",
        "default": true
      },
      {
        "type": "text",
        "id": "newsletter_heading",
        "label": "Newsletter heading",
        "default": "Sign up & save 10%"
      },
      {
        "type": "header",
        "content": "Column 1 Links"
      },
      {
        "type": "url",
        "id": "subscribe_url",
        "label": "Subscribe URL"
      },
      {
        "type": "url",
        "id": "member_url",
        "label": "Become a Member URL"
      },
      {
        "type": "url",
        "id": "refer_url",
        "label": "Refer a Friend URL"
      },
      {
        "type": "url",
        "id": "quiz_url",
        "label": "Take the Scent Quiz URL"
      },
      {
        "type": "url",
        "id": "store_url",
        "label": "Find a Store URL"
      },
      {
        "type": "header",
        "content": "Column 2 Links"
      },
      {
        "type": "url",
        "id": "help_url",
        "label": "Help Center URL"
      },
      {
        "type": "url",
        "id": "faq_url",
        "label": "FAQs URL"
      },
      {
        "type": "url",
        "id": "contact_url",
        "label": "Contact URL"
      },
      {
        "type": "header",
        "content": "Bottom Bar Links"
      },
      {
        "type": "url",
        "id": "accessibility_url",
        "label": "Accessibility URL"
      },
      {
        "type": "header",
        "content": "Social links"
      },
      {
        "type": "url",
        "id": "instagram_url",
        "label": "Instagram URL"
      },
      {
        "type": "url",
        "id": "tiktok_url",
        "label": "TikTok URL"
      },
      {
        "type": "url",
        "id": "facebook_url",
        "label": "Facebook URL"
      }
    ]
  }
{% endschema %}
