{% liquid
  assign primary_links = blank

  if section.settings.primary_menu != blank
    assign primary_links = section.settings.primary_menu.links
  elsif linklists.footer.links != blank
    assign primary_links = linklists.footer.links
  endif
%}

<div class="border-t border-gray-200 bg-gray-50">
  <div class="container px-6 py-12 md:px-8 md:py-14">
    <div class="grid gap-10 lg:grid-cols-12">
      <div class="lg:col-span-5">
        <h2 class="text-xl font-semibold text-cloud-burst-600 md:text-2xl">{{ shop.name }}</h2>
        <p class="mt-3 max-w-xl text-sm leading-6 text-gray-600">{{ section.settings.tagline }}</p>

        {% if section.settings.show_newsletter %}
          {% form 'customer', id: 'FooterNewsletter', class: 'mt-6 rounded-xl border border-gray-200 bg-white p-4 sm:p-5' %}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <h3 class="text-base font-semibold leading-6 text-cloud-burst-600">{{ section.settings.newsletter_heading }}</h3>
            <p id="FooterNewsletter-description" class="mt-1 text-sm leading-5 text-gray-600">Get product updates and occasional offers.</p>
            <div class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-stretch">
              <label class="sr-only" for="FooterNewsletter-email">Email address</label>
              <input
                id="FooterNewsletter-email"
                type="email"
                name="contact[email]"
                value="{% if customer %}{{ customer.email }}{% endif %}"
                autocomplete="email"
                required
                aria-describedby="FooterNewsletter-description"
                placeholder="Enter your email"
                class="h-11 w-full rounded-lg border border-gray-300 bg-white px-3.5 text-sm text-gray-900 placeholder:text-gray-400 focus-visible:border-cloud-burst-400 focus-visible:outline-none"
              >
              <button
                type="submit"
                class="inline-flex h-11 w-full items-center justify-center rounded-lg bg-cloud-burst-500 px-5 text-sm font-semibold text-white transition hover:bg-cloud-burst-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cloud-burst-500 sm:w-auto"
                name="commit"
              >
                {{ section.settings.newsletter_button_label }}
              </button>
            </div>
            {% if form.errors %}
              <div class="mt-3 text-sm text-rose-600">
                {{ form.errors | default_errors }}
              </div>
            {% elsif form.posted_successfully? %}
              <p class="mt-3 text-sm text-green-700">Thanks for subscribing.</p>
            {% endif %}
          {% endform %}
        {% endif %}
      </div>

      <div class="lg:col-span-3">
        <h3 class="text-sm font-semibold text-cloud-burst-600">Shop</h3>
        <nav class="mt-4" aria-label="Footer primary links">
          <ul class="space-y-2.5">
            {% for link in primary_links limit: 8 %}
              <li>
                <a
                  href="{{ link.url }}"
                  class="text-sm text-gray-600 no-underline transition hover:text-cloud-burst-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cloud-burst-400"
                >
                  {{ link.title }}
                </a>
              </li>
            {% endfor %}
          </ul>
        </nav>
      </div>

      <div class="lg:col-span-2">
        <h3 class="text-sm font-semibold text-cloud-burst-600">Policies</h3>
        <ul class="mt-4 space-y-2.5">
          {% if section.settings.secondary_menu != blank %}
            {% for link in section.settings.secondary_menu.links limit: 8 %}
              <li>
                <a
                  href="{{ link.url }}"
                  class="text-sm text-gray-600 no-underline transition hover:text-cloud-burst-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cloud-burst-400"
                >
                  {{ link.title }}
                </a>
              </li>
            {% endfor %}
          {% else %}
            {% if shop.privacy_policy != blank %}
              <li>
                <a href="{{ shop.privacy_policy.url }}" class="text-sm text-gray-600 no-underline transition hover:text-cloud-burst-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cloud-burst-400">{{ shop.privacy_policy.title }}</a>
              </li>
            {% endif %}
            {% if shop.refund_policy != blank %}
              <li>
                <a href="{{ shop.refund_policy.url }}" class="text-sm text-gray-600 no-underline transition hover:text-cloud-burst-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cloud-burst-400">{{ shop.refund_policy.title }}</a>
              </li>
            {% endif %}
            {% if shop.shipping_policy != blank %}
              <li>
                <a href="{{ shop.shipping_policy.url }}" class="text-sm text-gray-600 no-underline transition hover:text-cloud-burst-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cloud-burst-400">{{ shop.shipping_policy.title }}</a>
              </li>
            {% endif %}
            {% if shop.terms_of_service != blank %}
              <li>
                <a href="{{ shop.terms_of_service.url }}" class="text-sm text-gray-600 no-underline transition hover:text-cloud-burst-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cloud-burst-400">{{ shop.terms_of_service.title }}</a>
              </li>
            {% endif %}
          {% endif %}
        </ul>
      </div>

      <div class="lg:col-span-2">
        <h3 class="text-sm font-semibold text-cloud-burst-600">Support</h3>
        <ul class="mt-4 space-y-2.5 text-sm text-gray-600">
          {% if section.settings.support_email != blank %}
            <li>
              <a href="mailto:{{ section.settings.support_email }}" class="no-underline text-gray-600 transition hover:text-cloud-burst-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cloud-burst-400">{{ section.settings.support_email }}</a>
            </li>
          {% endif %}
          {% if section.settings.support_phone != blank %}
            <li>
              <a href="tel:{{ section.settings.support_phone | replace: ' ', '' }}" class="no-underline text-gray-600 transition hover:text-cloud-burst-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cloud-burst-400">{{ section.settings.support_phone }}</a>
            </li>
          {% endif %}
          {% if section.settings.support_hours != blank %}
            <li>{{ section.settings.support_hours }}</li>
          {% endif %}
        </ul>

        <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2">
          {% if section.settings.instagram_url != blank %}
            <a href="{{ section.settings.instagram_url }}" class="text-xs font-semibold uppercase tracking-[0.08em] text-gray-500 no-underline transition hover:text-cloud-burst-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cloud-burst-400">Instagram</a>
          {% endif %}
          {% if section.settings.facebook_url != blank %}
            <a href="{{ section.settings.facebook_url }}" class="text-xs font-semibold uppercase tracking-[0.08em] text-gray-500 no-underline transition hover:text-cloud-burst-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cloud-burst-400">Facebook</a>
          {% endif %}
          {% if section.settings.tiktok_url != blank %}
            <a href="{{ section.settings.tiktok_url }}" class="text-xs font-semibold uppercase tracking-[0.08em] text-gray-500 no-underline transition hover:text-cloud-burst-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cloud-burst-400">TikTok</a>
          {% endif %}
        </div>
      </div>
    </div>

    <div class="mt-10 border-t border-gray-200 pt-5">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <p class="text-xs text-gray-500">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
        {% if section.settings.show_payment_icons and shop.enabled_payment_types.size > 0 %}
          <ul class="flex flex-wrap items-center gap-2" role="list" aria-label="Accepted payment methods">
            {% for type in shop.enabled_payment_types %}
              <li class="rounded border border-gray-200 bg-white px-2 py-1">
                {{ type | payment_type_svg_tag: class: 'h-4 w-auto' }}
              </li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "Footer",
    "class": "footer",
    "tag": "footer",
    "settings": [
      {
        "type": "header",
        "content": "Content"
      },
      {
        "type": "textarea",
        "id": "tagline",
        "label": "Brand message",
        "default": "Thoughtfully selected products and dependable service, all in one place."
      },
      {
        "type": "link_list",
        "id": "primary_menu",
        "label": "Primary menu"
      },
      {
        "type": "link_list",
        "id": "secondary_menu",
        "label": "Secondary menu"
      },
      {
        "type": "header",
        "content": "Newsletter"
      },
      {
        "type": "checkbox",
        "id": "show_newsletter",
        "label": "Show newsletter signup",
        "default": true
      },
      {
        "type": "text",
        "id": "newsletter_heading",
        "label": "Newsletter heading",
        "default": "Join our newsletter"
      },
      {
        "type": "text",
        "id": "newsletter_button_label",
        "label": "Newsletter button label",
        "default": "Subscribe"
      },
      {
        "type": "header",
        "content": "Support"
      },
      {
        "type": "text",
        "id": "support_email",
        "label": "Support email",
        "default": "support@example.com"
      },
      {
        "type": "text",
        "id": "support_phone",
        "label": "Support phone",
        "default": "+1 (800) 555-0147"
      },
      {
        "type": "text",
        "id": "support_hours",
        "label": "Support hours",
        "default": "Mon-Fri, 9am-5pm"
      },
      {
        "type": "header",
        "content": "Social links"
      },
      {
        "type": "url",
        "id": "instagram_url",
        "label": "Instagram URL"
      },
      {
        "type": "url",
        "id": "facebook_url",
        "label": "Facebook URL"
      },
      {
        "type": "url",
        "id": "tiktok_url",
        "label": "TikTok URL"
      },
      {
        "type": "header",
        "content": "Layout"
      },
      {
        "type": "checkbox",
        "id": "show_payment_icons",
        "label": "Show payment icons",
        "default": true
      }
    ]
  }
{% endschema %}
