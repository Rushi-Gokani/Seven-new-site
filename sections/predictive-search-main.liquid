{% schema %}
{
  "name": "Predictive search",
  "class": "section-predictive-search",
  "tag": "div",
  "settings": [
    {
      "type": "paragraph",
      "content": "Messages animate inside the search input placeholder."
    },
    {
      "type": "text",
      "id": "prompt_text",
      "label": "Fallback placeholder text",
      "default": "What can we help you find?"
    },
    {
      "type": "header",
      "content": "Prompt messages"
    },
    {
      "type": "text",
      "id": "prompt_message_1",
      "label": "Message 1",
      "default": "What can we help you find?"
    },
    {
      "type": "text",
      "id": "prompt_message_2",
      "label": "Message 2",
      "default": "Try \"best sellers\""
    },
    {
      "type": "text",
      "id": "prompt_message_3",
      "label": "Message 3",
      "default": "Looking for gifts?"
    },
    {
      "type": "text",
      "id": "prompt_message_4",
      "label": "Message 4"
    },
    {
      "type": "text",
      "id": "prompt_message_5",
      "label": "Message 5"
    },
    {
      "type": "header",
      "content": "Typing animation"
    },
    {
      "type": "checkbox",
      "id": "enable_typed_messages",
      "label": "Enable typing animation",
      "default": true
    },
    {
      "type": "range",
      "id": "typing_speed",
      "min": 30,
      "max": 180,
      "step": 5,
      "unit": "ms",
      "label": "Typing speed",
      "default": 60
    },
    {
      "type": "range",
      "id": "deleting_speed",
      "min": 20,
      "max": 120,
      "step": 5,
      "unit": "ms",
      "label": "Deleting speed",
      "default": 35
    },
    {
      "type": "range",
      "id": "message_pause",
      "min": 500,
      "max": 4000,
      "step": 100,
      "unit": "ms",
      "label": "Pause between messages",
      "default": 1600
    }
  ]
}
{% endschema %}

<script src="{{ 'predictive-search.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign fallback_prompt = section.settings.prompt_text | strip
  assign prompt_message_count = 0
  assign initial_prompt_message = ''
  assign prompt_message_1 = section.settings.prompt_message_1 | strip
  assign prompt_message_2 = section.settings.prompt_message_2 | strip
  assign prompt_message_3 = section.settings.prompt_message_3 | strip
  assign prompt_message_4 = section.settings.prompt_message_4 | strip
  assign prompt_message_5 = section.settings.prompt_message_5 | strip

  capture prompt_messages_json
    echo '['
    assign needs_comma = false

    if prompt_message_1 != blank
      if needs_comma
        echo ','
      endif

      echo prompt_message_1 | json
      assign needs_comma = true
      assign prompt_message_count = prompt_message_count | plus: 1

      if initial_prompt_message == blank
        assign initial_prompt_message = prompt_message_1
      endif
    endif

    if prompt_message_2 != blank
      if needs_comma
        echo ','
      endif

      echo prompt_message_2 | json
      assign needs_comma = true
      assign prompt_message_count = prompt_message_count | plus: 1

      if initial_prompt_message == blank
        assign initial_prompt_message = prompt_message_2
      endif
    endif

    if prompt_message_3 != blank
      if needs_comma
        echo ','
      endif

      echo prompt_message_3 | json
      assign needs_comma = true
      assign prompt_message_count = prompt_message_count | plus: 1

      if initial_prompt_message == blank
        assign initial_prompt_message = prompt_message_3
      endif
    endif

    if prompt_message_4 != blank
      if needs_comma
        echo ','
      endif

      echo prompt_message_4 | json
      assign needs_comma = true
      assign prompt_message_count = prompt_message_count | plus: 1

      if initial_prompt_message == blank
        assign initial_prompt_message = prompt_message_4
      endif
    endif

    if prompt_message_5 != blank
      if needs_comma
        echo ','
      endif

      echo prompt_message_5 | json
      assign needs_comma = true
      assign prompt_message_count = prompt_message_count | plus: 1

      if initial_prompt_message == blank
        assign initial_prompt_message = prompt_message_5
      endif
    endif

    if prompt_message_count == 0 and fallback_prompt != blank
      echo fallback_prompt | json
      assign prompt_message_count = 1
      assign initial_prompt_message = fallback_prompt
    endif

    echo ']'
  endcapture

  assign prompt_messages_json = prompt_messages_json | strip
-%}

<predictive-search
  x-data
  x-cloak
  id="predictive-search"
  class="fixed inset-0 z-40 overflow-hidden [[x-cloak]]:hidden"
  x-show="$store.global.isPredictiveSearchVisible"
  x-trap.inert="$store.global.isPredictiveSearchVisible"
  x-transition.opacity.duration.200ms
  x-effect="
    document.body.classList.toggle('overflow-hidden', $store.global.isPredictiveSearchVisible);
    if ($store.global.isPredictiveSearchVisible) {
      $nextTick(() => $refs.predictiveSearchInput.focus());
    }
  "
  role="dialog"
  aria-modal="true"
  @click.self="$store.global.isPredictiveSearchVisible = false"
  @keyup.escape.window="$store.global.isPredictiveSearchVisible = false"
>
  <div class="absolute inset-0 bg-slate-950/50 backdrop-blur-[1.5px]" aria-hidden="true"></div>

  <div class="relative mx-auto flex h-full w-full items-start justify-center px-4 pb-4 pt-20 sm:px-6 sm:pb-6 sm:pt-24">
  <div
    id="predictive-search-form-wrapper"
    class="flex max-h-[calc(100dvh-6.5rem)] w-full max-w-3xl flex-col overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-2xl sm:max-h-[calc(100dvh-8rem)]"
  >
    <div class="border-b border-slate-200 bg-slate-50/80 px-5 py-4 sm:px-8">
      <div class="flex items-center justify-between gap-4">
        <p class="text-xs font-semibold tracking-[0.18em] text-slate-500 uppercase">Instant Search</p>
        <button
          type="button"
          class="inline-flex h-8 w-8 items-center justify-center rounded-full text-slate-500 transition hover:bg-slate-200 hover:text-slate-700 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-slate-400"
          @click="$store.global.isPredictiveSearchVisible = false"
          aria-label="Close instant search"
        >
          <span class="sr-only">Close instant search</span>
          {% render 'icon-close-x' %}
        </button>
      </div>
    </div>

    <form
      action="{{ routes.search_url }}"
      method="get"
      role="search"
      class="flex min-h-0 flex-col px-5 pb-6 pt-5 sm:px-8 sm:pb-8"
    >
      <label for="predictive-search-input" class="sr-only">Search the catalog</label>
      <div class="flex flex-col gap-3 sm:flex-row">
        <div class="relative flex-1">
          <span class="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 [&>svg]:h-5 [&>svg]:w-5">
            {% render 'icon-search' %}
          </span>
          <input
            x-ref="predictiveSearchInput"
            id="predictive-search-input"
            class="h-12 w-full rounded-xl border border-slate-300 bg-white pl-11 pr-16 text-base text-slate-900 transition placeholder:text-slate-400 focus:border-indigo-900 focus:outline-none focus:ring-2 focus:ring-indigo-900/25"
            type="search"
            name="q"
            value="{{ search.terms | escape }}"
            placeholder="{{ initial_prompt_message | default: 'Search products, collections, or pages' | escape }}"
            data-enable-typing="{{ section.settings.enable_typed_messages }}"
            data-typing-speed="{{ section.settings.typing_speed }}"
            data-deleting-speed="{{ section.settings.deleting_speed }}"
            data-message-pause="{{ section.settings.message_pause }}"
            data-messages='{{ prompt_messages_json | escape }}'
            data-fallback-placeholder="{{ initial_prompt_message | default: 'Search products, collections, or pages' | escape }}"
            autocomplete="off"
            spellcheck="false"
            role="combobox"
            aria-expanded="false"
            aria-owns="predictive-search-results"
            aria-controls="predictive-search-results"
            aria-haspopup="listbox"
            aria-autocomplete="list"
          >

          <button
            id="predictive-search-clear"
            type="button"
            class="absolute right-2 top-1/2 hidden -translate-y-1/2 rounded-md px-2 py-1 text-xs font-semibold text-slate-500 transition hover:bg-slate-100 hover:text-slate-700 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-slate-400"
          >
            Clear
          </button>
        </div>

        <button
          type="submit"
          class="h-12 rounded-xl bg-indigo-900 px-6 text-sm font-semibold tracking-wide text-white transition hover:bg-indigo-950 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-900"
        >
          Search
        </button>
      </div>

      <input name="options[prefix]" type="hidden" value="last">
      <p id="predictive-search-status" data-predictive-search-status class="mt-3 text-sm text-slate-500" aria-live="polite">
        Start typing to see quick product matches.
      </p>
      <div id="predictive-search-target" tabindex="-1" class="mt-4 min-h-0 flex-1 overflow-hidden pb-2 pr-2" hidden></div>
    </form>
  </div>
</div>
</predictive-search>

<style>
  #predictive-search-input[type='search'] {
    -webkit-appearance: none;
    appearance: none;
  }

  #predictive-search-input::-webkit-search-cancel-button {
    -webkit-appearance: none;
    appearance: none;
    display: none;
  }
</style>
