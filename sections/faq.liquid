{% schema %}
{
  "name": "FAQ Section",
  "class": "faq-section",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Find answers to common questions below"
    },
    {
      "type": "select",
      "id": "background",
      "label": "Background style",
      "options": [
        { "value": "none", "label": "None (white)" },
        { "value": "light", "label": "Light gray" },
        { "value": "dark", "label": "Dark (cloud-burst)" }
      ],
      "default": "none"
    },
    {
      "type": "checkbox",
      "id": "show_icons",
      "label": "Show expand/collapse icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "name": "Question",
      "type": "question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What is your return policy?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>We offer a 30-day return policy for all unused items in their original packaging. Simply contact our support team to initiate a return.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Section",
      "blocks": [
        {
          "type": "question",
          "settings": {
            "question": "What is your return policy?",
            "answer": "<p>We offer a 30-day return policy for all unused items in their original packaging. Simply contact our support team to initiate a return.</p>"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "How long does shipping take?",
            "answer": "<p>Standard shipping typically takes 5-7 business days. Express shipping options are available at checkout for faster delivery.</p>"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "Do you offer international shipping?",
            "answer": "<p>Yes! We ship to over 100 countries worldwide. Shipping costs and delivery times vary by location.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}

{%- liquid
  assign bg_class = ''
  assign text_class = ''
  
  if section.settings.background == 'light'
    assign bg_class = 'bg-gray-50'
  elsif section.settings.background == 'dark'
    assign bg_class = 'bg-cloud-burst-600'
    assign text_class = 'text-white'
  endif
-%}

<section class="faq-section px-6 py-16 md:px-8 md:py-24 {{ bg_class }}" aria-labelledby="faq-heading">
  <div class="container">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="mb-12 text-center {{ text_class }} max-w-2xl mx-auto">
        {%- if section.settings.heading != blank -%}
          <h2 id="faq-heading" class="mb-4 text-3xl font-bold md:text-4xl">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="text-lg text-gray-500{% if section.settings.background == 'dark' %} !text-gray-300{% endif %}">
            {{ section.settings.subheading }}
          </p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="faq-list mx-auto max-w-3xl">
        {%- for block in section.blocks -%}
          <div
            x-data="{ expanded: false }"
            class="faq-item mb-4"
            x-id="['faq-panel']"
            {{ block.shopify_attributes }}
          >
            <button
              type="button"
              class="faq-trigger group flex w-full items-center justify-between rounded-xl border border-gray-200 bg-white p-5 text-left transition-all hover:border-cloud-burst-300{% if section.settings.background == 'dark' %} !border-cloud-burst-400 !bg-cloud-burst-500 !text-white{% endif %}"
              @click="expanded = !expanded"
              :aria-expanded="expanded"
              :aria-controls="$id('faq-panel')"
            >
              <span class="font-semibold text-gray-900 pr-4{% if section.settings.background == 'dark' %} !text-white{% endif %}">
                {{ block.settings.question }}
              </span>
              {%- if section.settings.show_icons -%}
                <span class="faq-icon flex-shrink-0 ml-2 relative w-5 h-5">
                  <span class="absolute inset-0 flex items-center justify-center transition-transform duration-300" :class="{ 'rotate-180': expanded }">
                    <svg class="w-5 h-5 text-cloud-burst-600{% if section.settings.background == 'dark' %} !text-cloud-burst-200{% endif %}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </span>
                </span>
              {%- endif -%}
            </button>
            
            <div
              x-cloak
              x-show="expanded"
              x-collapse
              :id="$id('faq-panel')"
              class="faq-answer overflow-hidden"
            >
              <div class="bg-white rounded-b-xl border-x border-b border-gray-200 p-5{% if section.settings.background == 'dark' %} !bg-cloud-burst-500 !border-cloud-burst-400{% endif %}">
                <div class="prose prose-gray max-w-none{% if section.settings.background == 'dark' %} !prose-invert{% endif %}">
                  {{ block.settings.answer }}
                </div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="text-center py-12 text-gray-500">
        <p>Add questions by clicking "Add block" in the theme editor.</p>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
[x-cloak] {
  display: none !important;
}
</style>
