{% schema %}
{
  "name": "Shop by Category",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Shop by Category"
    },
    {
      "type": "text",
      "id": "shop_all_text",
      "label": "Shop All Link Text",
      "default": "SHOP ALL"
    },
    {
      "type": "url",
      "id": "shop_all_link",
      "label": "Shop All Link"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Category Title",
          "default": "Deodorant"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "SHOP DEODORANT"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Category Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Category",
      "blocks": [
        { "type": "category", "settings": { "title": "Deodorant", "button_text": "SHOP DEODORANT" } },
        { "type": "category", "settings": { "title": "Body Wash", "button_text": "SHOP BODY WASH" } },
        { "type": "category", "settings": { "title": "Body Mist", "button_text": "SHOP BODY MIST" } },
        { "type": "category", "settings": { "title": "Body Cream", "button_text": "SHOP BODY CREAM" } }
      ]
    }
  ]
}
{% endschema %}

<div class="shop-by-category py-20 lg:py-24" style="background-color: {{ section.settings.bg_color }};">
  <div class="max-w-[1540px] mx-auto px-6 md:px-12">
    
    <!-- Section Header -->
    <div class="flex justify-between items-baseline mb-12">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tighter text-black">
        {{ section.settings.title }}
      </h2>
      {% if section.settings.shop_all_link != blank %}
        <a href="{{ section.settings.shop_all_link }}" class="text-[11px] font-bold uppercase tracking-[0.2em] text-black underline underline-offset-4 hover:opacity-70 transition-opacity">
          {{ section.settings.shop_all_text }}
        </a>
      {% endif %}
    </div>

    <!-- Category Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {%- for block in section.blocks -%}
        <div class="group relative aspect-[3/4] overflow-hidden rounded-[48px] bg-[#f8f8f8]" {{ block.shopify_attributes }}>
          
          <!-- Image -->
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 800 | image_tag:
              class: 'absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105',
              loading: 'lazy'
            }}
          {%- else -%}
             <div class="absolute inset-0 flex items-center justify-center bg-gray-100">
               {{ 'image' | placeholder_svg_tag: 'w-20 h-20 opacity-20' }}
             </div>
          {%- endif -%}

          <!-- Overlay (Subtle Gradient for Title Readability) -->
          <div class="absolute inset-0 z-10 bg-gradient-to-b from-black/20 via-transparent to-transparent"></div>

          <!-- Content Wrapper -->
          <div class="absolute inset-0 z-20 p-8 flex flex-col justify-between">
            <!-- Title (Top Left) -->
            <h3 class="text-2xl md:text-3xl font-medium text-white tracking-tight">
              {{ block.settings.title }}
            </h3>

            <!-- Link/Button (Bottom Left) -->
            {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}" class="inline-flex items-center justify-center gap-10 px-11 py-4 bg-white text-black rounded-full uppercase tracking-[0.1em] text-[11px] font-bold transition-all duration-300 hover:bg-gray-100 group/btn whitespace-nowrap w-fit">
              <span>{{ block.settings.button_text }}</span>
              <svg width="20" height="12" viewBox="0 0 24 24" fill="none" class="transition-transform duration-300 group-hover/btn:translate-x-1.5 shrink-0" xmlns="http://www.w3.org/2000/svg">
                <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            {% endif %}
          </div>

          <!-- Clickable whole card area if link exists -->
          {% if block.settings.link != blank %}
             <a href="{{ block.settings.link }}" class="absolute inset-0 z-10 block" aria-label="{{ block.settings.title }}"></a>
          {% endif %}
        </div>
      {%- endfor -%}
    </div>

  </div>
</div>
