{% schema %}
{
  "name": "Shop by Category",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Shop by Category"
    },
    {
      "type": "text",
      "id": "shop_all_text",
      "label": "Shop All Link Text",
      "default": "SHOP ALL"
    },
    {
      "type": "url",
      "id": "shop_all_link",
      "label": "Shop All Link"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Category Title",
          "default": "Deodorant"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "SHOP DEODORANT"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Category Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Category",
      "blocks": [
        { "type": "category", "settings": { "title": "Deodorant", "button_text": "SHOP DEODORANT" } },
        { "type": "category", "settings": { "title": "Body Wash", "button_text": "SHOP BODY WASH" } },
        { "type": "category", "settings": { "title": "Body Mist", "button_text": "SHOP BODY MIST" } },
        { "type": "category", "settings": { "title": "Body Cream", "button_text": "SHOP BODY CREAM" } }
      ]
    }
  ]
}
{% endschema %}

<style>
  .shop-by-category-wrapper {
    padding: 80px;
    overflow: hidden;
  }
  .category-scroller {
    display: flex;
    gap: 24px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    cursor: grab;
  }
  .category-item {
    flex: 0 0 calc(25% - 18px); /* 4 columns for desktop */
    scroll-snap-align: start;
    position: relative;
  }
  .category-card-container {
    position: relative;
    aspect-ratio: 2/3.1;
    border-radius: 8px;
    overflow: hidden;
    background-color: #f8f8f8;
    isolation: isolate;
  }
  .category-card-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .category-card-container:hover .category-card-image {
    transform: scale(1.05);
  }
  .category-card-overlay {
    position: absolute;
    inset: 0;
    z-index: 10;
    background: linear-gradient(to bottom, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0) 30%);
  }
  .category-card-content {
    position: absolute;
    inset: 0;
    z-index: 20;
    padding: 32px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    pointer-events: none;
  }
  .category-card-title {
    color: white !important;
    font-size: 32px;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .category-button-wrap {
    width: 100%;
    display: flex;
    justify-content: flex-start;
    pointer-events: auto;
  }
  .category-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 10px 24px;
    background-color: white !important;
    color: black !important;
    border-radius: 100px;
    text-transform: uppercase;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-decoration: none;
    transition: all 0.3s ease;
    white-space: nowrap;
    width: fit-content;
  }
  .category-button:hover {
    background-color: black !important;
    color: white !important;
  }
  .category-button svg {
    transition: transform 0.3s ease;
    flex-shrink: 0;
  }
  .category-button:hover svg {
    transform: translateX(4px);
  }
  
  /* Mobile Styles */
  @media (max-width: 768px) {
    .shop-by-category-wrapper { padding: 0px 10px 40px 20px; }
    .category-container { padding: 0 20px; }
    .category-scroller { 
      padding: 0 20px; 
      margin: 0 -20px; 
      gap: 12px;
    }
    .category-item { flex: 0 0 82%; } /* Salt & Stone width */
    .category-card-title { font-size: 24px !important; font-weight: 600 !important; padding-top: 0; }
    .category-card-content { padding: 20px; }
    .category-button { padding: 8px 18px; font-size: 10px; }
    
    .category-header { 
      display: flex; 
      justify-content: space-between; 
      align-items: baseline; 
      margin-bottom: 24px; 
      padding: 0; 
      margin-left: -24px;
    }
    .category-container { padding: 0 20px; }
    .category-section-title { 
      font-size: 24px !important; 
      font-weight: 600 !important;
      letter-spacing: -0.02em !important;
    }
    .category-card-title { font-size: 24px !important; font-weight: 600 !important; padding-top: 5px; }
  }

  @media (min-width: 769px) {
    .category-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 40px; }
    .category-section-title { font-size: 32px; font-weight: 600; margin: 0; letter-spacing: -0.02em; }
    .category-scroller { overflow-x: visible; gap: 24px; cursor: default; }
  }

  .category-shop-all {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #000;
    text-decoration: underline;
    text-underline-offset: 4px;
    white-space: nowrap;
    transition: opacity 0.3s ease;
  }
  /* Hide Scrollbar */
  .hide-scrollbar::-webkit-scrollbar { display: none; }
  .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<div 
  class="shop-by-category-wrapper" 
  style="background-color: {{ section.settings.bg_color }};"
  x-data="{ 
    progress: 0,
    isDown: false,
    startX: 0,
    scrollLeft: 0,
    startDrag(e) {
      if (window.innerWidth > 768) return;
      this.isDown = true;
      this.startX = e.pageX - this.$refs.scroller.offsetLeft;
      this.scrollLeft = this.$refs.scroller.scrollLeft;
      this.$refs.scroller.style.scrollSnapType = 'none';
      this.$refs.scroller.style.cursor = 'grabbing';
    },
    endDrag() {
      this.isDown = false;
      this.$refs.scroller.style.scrollSnapType = 'x mandatory';
      this.$refs.scroller.style.cursor = 'grab';
    },
    drag(e) {
      if (!this.isDown) return;
      e.preventDefault();
      const x = e.pageX - this.$refs.scroller.offsetLeft;
      const walk = (x - this.startX) * 1.5; 
      this.$refs.scroller.scrollLeft = this.scrollLeft - walk;
    }
  }"
>
  <div class="max-w-[1540px] mx-auto category-container">
    
    <!-- Header -->
    <div class="category-header">
      <h2 class="category-section-title text-black m-0">
        {{ section.settings.title }}
      </h2>
      {% if section.settings.shop_all_link != blank %}
        <a href="{{ section.settings.shop_all_link }}" class="category-shop-all">
          {{ section.settings.shop_all_text }}
        </a>
      {% endif %}
    </div>

    <!-- Scroller -->
    <div 
      x-ref="scroller"
      class="category-scroller hide-scrollbar"
      @mousedown="startDrag($event)"
      @mouseleave="endDrag()"
      @mouseup="endDrag()"
      @mousemove="drag($event)"
    >
      {%- for block in section.blocks -%}
        <div class="category-item" {{ block.shopify_attributes }}>
          <div class="category-card-container">
            
            <!-- Image -->
            {%- if block.settings.image != blank -%}
              <img 
                src="{{ block.settings.image | image_url: width: 800 }}" 
                alt="{{ block.settings.title }}"
                class="category-card-image"
                loading="lazy"
                width="800"
                height="1200"
              >
            {%- else -%}
               <div class="category-card-image bg-gray-100 flex items-center justify-center">
                 {{ 'image' | placeholder_svg_tag: 'w-20 h-20 opacity-10' }}
               </div>
            {%- endif -%}

            <div class="category-card-overlay"></div>

            <!-- Content -->
            <div class="category-card-content">
              <h3 class="category-card-title">{{ block.settings.title }}</h3>

              {% if block.settings.link != blank %}
                <div class="category-button-wrap">
                  <a href="{{ block.settings.link }}" class="category-button">
                    <span>{{ block.settings.button_text }}</span>
                    <svg width="15" height="10" viewBox="0 0 15 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M10 1L14 5L10 9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M1 5H14" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                </div>
              {% endif %}
            </div>

            <!-- Clickable whole card area if link exists -->
            {% if block.settings.link != blank %}
               <a href="{{ block.settings.link }}" class="absolute inset-0 z-30 block" aria-label="{{ block.settings.title }}"></a>
            {% endif %}
          </div>
        </div>
      {%- endfor -%}
    </div>

  </div>
</div>
