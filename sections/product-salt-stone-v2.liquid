{% comment %}
  Salt & Stone Product Page - Simplified Version
{% endcomment %}

{% schema %}
{
  "name": "Product Salt Stone V2",
  "tag": "section",
  "class": "section-product-salt-stone",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "BEST SELLER"
    }
  ],
  "blocks": [
    {
      "type": "title",
      "name": "Title"
    },
    {
      "type": "description",
      "name": "Description"
    },
    {
      "type": "rating",
      "name": "Review/Rating",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "star_rating",
          "label": "Star Rating",
          "default": "4.9"
        },
        {
          "type": "text",
          "id": "review_count",
          "label": "Review Count",
          "default": "5,540 reviews"
        }
      ]
    },
    {
      "type": "afterpay",
      "name": "Afterpay Message",
      "limit": 1
    },
    {
      "type": "buy_buttons",
      "name": "Buy Buttons"
    },
    {
      "type": "text",
      "name": "Custom Text",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Add <b>bold</b> or <u>underline</u> text here.</p>"
        }
      ]
    },
    {
      "type": "promo_bar",
      "name": "Promo Bar",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Promo Text",
          "default": "Get a free Mini Santal Deodorant on orders $65+"
        }
      ]
    },
    {
      "type": "accordion",
      "name": "Accordion",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Accordion Heading"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Add content here for your accordion.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Salt Stone",
      "blocks": [
        { "type": "title" },
        { "type": "description" },
        { "type": "rating" },
        { "type": "buy_buttons" }
      ]
    }
  ]
}
{% endschema %}

{%- assign product = all_products[section.settings.product] | default: product -%}

{% if product %}
  {%- assign current_variant = product.selected_or_first_available_variant -%}
  {%- assign image_media = product.media | where: "media_type", "image" -%}

  <div 
    class="product-salt-stone" 
    data-section-id="{{ section.id }}"
    x-data="{ 
      activeIndex: 0,
      totalImages: {{ image_media.size }},
      showCursor: false,
      cursorSide: 'right',
      cursorX: 0,
      cursorY: 0,
      goTo(index) {
        if (index < 0) index = this.totalImages - 1;
        if (index >= this.totalImages) index = 0;
        this.activeIndex = index;
        const scrollAmount = this.$refs.mainGallery.offsetWidth * index;
        this.$refs.mainGallery.scrollTo({
          left: scrollAmount,
          behavior: 'smooth'
        });
      }
    }"
  >
    <div class="product-grid">
      
      <!-- Thumbnails -->
      <div class="product-thumbs">
        {% for media in image_media %}
          <div 
            class="thumb"
            @click="goTo({{ forloop.index0 }})"
            :class="{ 'is-active': activeIndex === {{ forloop.index0 }} }"
          >
            {{ media | image_url: width: 150 | image_tag }}
          </div>
        {% endfor %}
      </div>
      
      <!-- Main Image Scroller -->
      <div 
        class="product-main"
        @mousemove="
          const rect = $el.getBoundingClientRect();
          const x = $event.clientX - rect.left;
          cursorSide = x < rect.width / 2 ? 'left' : 'right';
          showCursor = true;
          cursorX = $event.clientX;
          cursorY = $event.clientY;
        "
        @mouseleave="showCursor = false"
        @click="cursorSide === 'left' ? goTo(activeIndex - 1) : goTo(activeIndex + 1)"
      >
        <span class="badge">{{ section.settings.badge_text }}</span>
        
        <div 
          x-ref="mainGallery"
          class="main-gallery-scroller hide-scrollbar"
          @scroll.debounce.100ms="activeIndex = Math.round($event.target.scrollLeft / $event.target.offsetWidth)"
        >
          {% for media in image_media %}
            <div class="gallery-slide">
              {{ media | image_url: width: 1200 | image_tag: class: 'gallery-img' }}
            </div>
          {% endfor %}
        </div>

        <!-- Custom Cursor -->
        <div 
          class="gallery-custom-cursor"
          x-show="showCursor"
          :style="`left: ${cursorX}px; top: ${cursorY}px;`"
          x-cloak
        >
          <svg x-show="cursorSide === 'left'" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"></polyline></svg>
          <svg x-show="cursorSide === 'right'" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </div>

        <!-- Pagination Dots -->
        <div class="gallery-pagination">
          {% for i in (1..image_media.size) %}
            <button 
              @click="goTo({{ forloop.index0 }})"
              class="pagination-dot"
              :class="{ 'is-active': activeIndex === {{ forloop.index0 }} }"
              aria-label="Go to image {{ forloop.index }}"
            ></button>
          {% endfor %}
        </div>
      </div>
      
      <!-- Product Info -->
      <div class="product-info">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'title' %}
              <h1 class="product-title">{{ product.title }}</h1>
            {% when 'description' %}
              <div class="product-desc">{{ product.description }}</div>
            {% when 'rating' %}
              <div class="rating-container" {{ block.shopify_attributes }}>
                <div class="stars">
                  {% for i in (1..5) %}
                    <svg class="star-icon" viewBox="0 0 20 20"><path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/></svg>
                  {% endfor %}
                </div>
                <span class="rating-text">
                  <span class="rating-value">{{ block.settings.star_rating }}</span>
                  <span class="review-count">({{ block.settings.review_count }})</span>
                </span>
              </div>

            {% when 'afterpay' %}
              <div class="afterpay-installment mb-4" {{ block.shopify_attributes }}>
                or 4 interest-free payments of <span>{{ product.price | divided_by: 4.0 | money }}</span> with 
                <span class="afterpay-logo">
                  <span class="afterpay-badge">S</span> Afterpay
                </span>
                <span class="afterpay-info">ⓘ</span>
              </div>

            {% when 'buy_buttons' %}
              {% form 'product', product %}
                <input type="hidden" name="id" value="{{ current_variant.id }}">
                <button type="submit" class="btn-add">ADD TO CART</button>
              {% endform %}
            {% when 'text' %}
              <div class="product-text-custom prose-sm mb-4" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </div>
            {% when 'promo_bar' %}
              <div class="promo-bar-pill mb-6" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </div>
            {% when 'accordion' %}
              <div 
                class="product-accordion" 
                x-data="{ open: false }" 
                {{ block.shopify_attributes }}
              >
                <button 
                  @click="open = !open" 
                  class="accordion-header"
                  :class="{ 'is-active': open }"
                >
                  <span>{{ block.settings.heading }}</span>
                  <span class="icon">
                    <svg x-show="!open" viewBox="0 0 20 20"><path d="M11 9V0H9v9H0v2h9v9h2v-9h9V9h-9z"/></svg>
                    <svg x-show="open" viewBox="0 0 20 20"><path d="M0 9h20v2H0V9z"/></svg>
                  </span>
                </button>
                <div 
                  class="accordion-content" 
                  x-show="open" 
                  x-collapse 
                  style="display: none;"
                >
                  <div class="content-inner">
                    {{ block.settings.content }}
                  </div>
                </div>
              </div>
{% endcase %}
        {% endfor %}
      </div>
      
    </div>
  </div>
{% else %}
  <div class="product-salt-stone placeholder" style="padding: 40px; text-align: center; background: #f9f9f9;">
    <p>Please select a product in the section settings to display this component.</p>
  </div>
{% endif %}

<style>
.product-salt-stone {
  max-width: 1400px;
  margin: 0 auto;
  padding: 40px 20px;
}
.product-grid {
  display: grid;
  grid-template-columns: 80px 1fr 400px;
  gap: 40px;
}
.product-thumbs {
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.thumb {
  cursor: pointer;
  border: 2px solid transparent;
  border-radius: 10px;
  overflow: hidden;
  transition: border-color 0.2s ease;
}
.thumb.is-active {
  border-color: #000;
}
.thumb img {
  width: 100%;
  display: block;
}
.product-main {
  position: relative;
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  cursor: none;
}
.gallery-custom-cursor {
  position: fixed;
  width: 60px;
  height: 60px;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  z-index: 1000;
  transform: translate(-50%, -50%);
  color: #000;
  transition: transform 0.1s ease-out;
}
.gallery-custom-cursor svg {
  width: 32px;
  height: 32px;
  fill: none;
  stroke: currentColor;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
  filter: drop-shadow(0 0 1px rgba(255,255,255,0.5));
}
[x-cloak] { display: none !important; }
.main-gallery-scroller {
  display: flex;
  overflow-x: auto;
  snap-type: x mandatory;
  scroll-behavior: smooth;
  -webkit-overflow-scrolling: touch;
}
.gallery-slide {
  flex: 0 0 100%;
  width: 100%;
  snap-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  aspect-ratio: 1 / 1.1;
}
.gallery-img {
  max-width: 100%;
  height: 100%;
  object-contain: cover;
}
.gallery-pagination {
  position: absolute;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 8px;
  z-index: 10;
}
.pagination-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #ccc;
  border: none;
  padding: 0;
  cursor: pointer;
  transition: all 0.2s ease;
}
.pagination-dot.is-active {
  background: #000;
  transform: scale(1.2);
}
.hide-scrollbar {
  scrollbar-width: none;
  -ms-overflow-style: none;
}
.hide-scrollbar::-webkit-scrollbar {
  display: none;
}
.badge {
  position: absolute;
  top: 20px;
  left: 20px;
  background: white;
  padding: 8px 16px;
  font-size: 10px;
  font-weight: bold;
  letter-spacing: 1px;
}
.product-main img {
  max-width: 100%;
  height: auto;
}
.product-title {
  font-size: 28px;
  font-weight: bold;
  text-transform: uppercase;
  margin: 0 0 20px;
}
.product-desc {
  color: #666;
  line-height: 1.6;
  margin-bottom: 20px;
}
.btn-add {
  width: 100%;
  padding: 18px;
  background: black;
  color: white;
  border: none;
  border-radius: 999px;
  font-weight: bold;
  cursor: pointer;
}
.rating-container {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-top: 20px;
  margin-bottom: 40px;
}
.stars {
  display: flex;
  gap: 2px;
}
.star-icon {
  width: 14px;
  height: 14px;
  fill: #000;
}
.rating-text {
  font-size: 14px;
  color: #666;
  display: flex;
  gap: 5px;
}
.rating-value {
  font-weight: bold;
  color: #000;
}
.promo-bar-pill {
  background: #f3f3f3;
  border-radius: 999px;
  padding: 12px 20px;
  text-align: center;
  font-size: 13px;
  color: #000;
  font-weight: 500;
}
.afterpay-installment {
  font-size: 13px;
  color: #888;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 4px;
  margin-top: 20px;
  margin-bottom: 20px;
}
.afterpay-installment span {
  font-weight: 600;
  color: #666;
}
.afterpay-logo {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  color: #000 !important;
  font-weight: 700 !important;
}
.afterpay-badge {
  background: #b2fce4;
  color: #000;
  width: 18px;
  height: 18px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 4px;
  font-size: 11px;
  font-weight: 900;
}
.afterpay-info {
  font-size: 14px;
  cursor: pointer;
  margin-left: 2px;
}
/* Accordion */
.product-accordion {
  border-bottom: 1px solid #e5e5e5;
}
.product-accordion:first-of-type {
  border-top: 1px solid #e5e5e5;
}
.accordion-header {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px 0;
  background: none;
  border: none;
  cursor: pointer;
  text-align: left;
  font-size: 14px;
  font-weight: 600;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: #000;
}
.accordion-header .icon svg {
  width: 14px;
  height: 14px;
  fill: currentColor;
}
.accordion-content {
  overflow: hidden;
}
.content-inner {
  padding-bottom: 20px;
  font-size: 14px;
  line-height: 1.6;
  color: #666;
}
.content-inner p {
  margin: 0 0 1rem;
}
@media (max-width: 768px) {
  .product-grid {
    grid-template-columns: 1fr;
  }
  .product-thumbs {
    flex-direction: row;
    overflow-x: auto;
  }
}
</style>
