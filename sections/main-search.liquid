{% schema %}
{
  "name": "Search Section",
  "class": "section-main-search",
  "tag": "section",
  "settings": []
}
{% endschema %}

{% comment %}
  Docs on the Shopify search object
  https://shopify.dev/api/liquid/objects/search#search-results
{% endcomment %}

<div class="bg-gradient-to-b from-slate-50 via-white to-white px-4 py-10 sm:px-6 lg:px-8">
  <div class="search-inner container mx-auto max-w-6xl">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
      <p class="text-xs font-semibold tracking-[0.2em] text-slate-500 uppercase">Search</p>
      {% if search.performed %}
        <h1 class="mt-2 text-3xl font-semibold text-slate-900 sm:text-4xl">Results for "{{ search.terms | escape }}"</h1>
        <p class="mt-2 text-sm text-slate-600">{{ search.results_count }} result{% if search.results_count != 1 %}s{% endif %} found.</p>
      {% else %}
        <h1 class="mt-2 text-3xl font-semibold text-slate-900 sm:text-4xl">Find your next favorite item</h1>
        <p class="mt-2 text-sm text-slate-600">Search products, pages, and articles from across the store.</p>
      {% endif %}

      <form action="{{ routes.search_url }}" class="mt-6 flex flex-col gap-3 sm:flex-row" role="search">
        <label for="search-page-input" class="sr-only">Search catalog</label>
        <input
          id="search-page-input"
          type="search"
          placeholder="Try: hoodie, accessories, gift"
          name="q"
          value="{{ search.terms | escape }}"
          class="h-12 w-full rounded-xl border border-slate-300 px-4 text-slate-900 transition placeholder:text-slate-400 focus:border-indigo-900 focus:outline-none focus:ring-2 focus:ring-indigo-900/25"
          autocomplete="off"
        >
        <input name="options[prefix]" type="hidden" value="last">
        <button type="submit" class="h-12 rounded-xl bg-indigo-900 px-7 text-sm font-semibold tracking-wide text-white transition hover:bg-indigo-950 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-900">
          Search
        </button>
      </form>
    </div>

    {% if search.performed %}
      {% if search.results.size > 0 %}
        {%- paginate search.results by 12 -%}
          <div class="product-grid mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
            {% for item in search.results %}
              {% case item.object_type %}
                {% when 'product' %}
                  {% render 'product-grid-item', product: item %}
                {% when 'article' %}
                  <article class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
                    {% if item.image %}
                      <img
                        src="{{ item.image | image_url: width: 640 }}"
                        srcset="{{ item.image | image_url: width: 320 }} 1x, {{ item.image | image_url: width: 640 }} 2x"
                        loading="lazy"
                        decoding="async"
                        width="{{ item.image.width }}"
                        height="{{ item.image.height }}"
                        alt="{{ item.image.alt | default: item.title | escape }}"
                        class="h-44 w-full rounded-xl object-cover"
                      >
                    {% endif %}
                    <div class="mt-3">
                      <a href="{{ item.url }}" class="text-base font-semibold text-slate-900 transition hover:text-indigo-900">
                        {{ item.title }}
                      </a>
                      <p class="mt-2 text-sm text-slate-600">
                        {{ item.excerpt_or_content | strip_html | truncate: 120 }}
                      </p>
                    </div>
                  </article>
                {% when 'page' %}
                  <article class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
                    {% if item.featured_image %}
                      <img
                        src="{{ item.featured_image | image_url: width: 640 }}"
                        srcset="{{ item.featured_image | image_url: width: 320 }} 1x, {{ item.featured_image | image_url: width: 640 }} 2x"
                        loading="lazy"
                        decoding="async"
                        width="{{ item.featured_image.width }}"
                        height="{{ item.featured_image.height }}"
                        alt="{{ item.featured_image.alt | default: item.title | escape }}"
                        class="h-44 w-full rounded-xl object-cover"
                      >
                    {% else %}
                      <div class="flex h-44 w-full items-center justify-center rounded-xl bg-slate-100 text-sm font-medium text-slate-500">
                        Page result
                      </div>
                    {% endif %}
                    <div class="mt-3">
                      <a href="{{ item.url }}" class="text-base font-semibold text-slate-900 transition hover:text-indigo-900">
                        {{ item.title }}
                      </a>
                    </div>
                  </article>
                {% else %}
                  <div class="rounded-2xl border border-slate-200 bg-white p-4 text-sm text-slate-600 shadow-sm">
                    This result type is not supported in this view.
                  </div>
              {% endcase %}
            {% endfor %}
          </div>
          <div class="mt-8">
            {% render 'pagination-navigation', paginate: paginate %}
          </div>
        {% endpaginate %}
      {% else %}
        <div class="mt-8 rounded-2xl border border-dashed border-slate-300 bg-white p-8 text-center shadow-sm">
          <h2 class="text-xl font-semibold text-slate-900">No results found</h2>
          <p class="mt-2 text-sm text-slate-600">Try a different keyword, check your spelling, or use fewer words.</p>
        </div>
      {% endif %}
    {% endif %}
  </div>
</div>
