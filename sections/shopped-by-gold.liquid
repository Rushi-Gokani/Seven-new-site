{% schema %}
{
  "name": "Shopped by Gold",
  "class": "section-shopped-by-gold",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Shopped by Gold"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Medium" },
        { "value": "h1", "label": "Large" },
        { "value": "h0", "label": "Extra large" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "items_per_view",
      "min": 1,
      "max": 6,
      "step": 1,
      "label": "Items per view (desktop)",
      "default": 4
    },
    {
      "type": "range",
      "id": "items_per_view_mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Items per view (mobile)",
      "default": 2
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show navigation arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Autoplay speed",
      "default": 5
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "collection_item",
      "name": "Collection Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom title (optional)",
          "info": "Leave empty to use collection title"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Shop Now"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shopped by Gold",
      "blocks": [
        {
          "type": "collection_item"
        },
        {
          "type": "collection_item"
        },
        {
          "type": "collection_item"
        },
        {
          "type": "collection_item"
        }
      ]
    }
  ]
}
{% endschema %}

<section
  class="shopped-by-gold-section relative bg-white"
  style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
  x-data="shoppedByGoldCarousel({
    itemsPerView: {{ section.settings.items_per_view }},
    itemsPerViewMobile: {{ section.settings.items_per_view_mobile }},
    autoplay: {{ section.settings.autoplay }},
    autoplaySpeed: {{ section.settings.autoplay_speed }}
  })"
  x-init="init()"
  @mouseenter="pause()"
  @mouseleave="resume()"
>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    {%- if section.settings.heading != blank -%}
      <div class="mb-8 text-{{ section.settings.heading_alignment }}">
        <h2 class="{{ section.settings.heading_size }} font-bold text-gray-900">
          {{ section.settings.heading }}
        </h2>
      </div>
    {%- endif -%}

    <div class="relative">
      <!-- Carousel Container -->
      <div class="overflow-hidden">
        <div
          class="carousel-track flex transition-transform duration-500 ease-in-out"
          :style="`transform: translateX(-${currentPosition}%)`"
        >
          {%- for block in section.blocks -%}
            {%- assign collection = collections[block.settings.collection] -%}
            {%- assign item_title = block.settings.custom_title | default: collection.title | default: 'Collection' -%}
            
            <div
              class="carousel-item flex-shrink-0 w-full px-2"
              :style="`width: ${itemWidth}%`"
              {{ block.shopify_attributes }}
            >
              <div class="group relative overflow-hidden rounded-lg shadow-md transition-all duration-300 hover:shadow-xl">
                {%- if block.settings.image != blank -%}
                  <a href="{{ collection.url }}" class="block" aria-label="{{ item_title | escape }}">
                    <img
                      src="{{ block.settings.image | image_url: width: 600 }}"
                      srcset="{{ block.settings.image | image_url: width: 400 }} 400w,
                              {{ block.settings.image | image_url: width: 600 }} 600w,
                              {{ block.settings.image | image_url: width: 800 }} 800w"
                      sizes="(max-width: 768px) 50vw, 25vw"
                      alt="{{ block.settings.image.alt | default: item_title | escape }}"
                      class="h-64 w-full object-cover transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                      width="{{ block.settings.image.width }}"
                      height="{{ block.settings.image.height }}"
                    >
                  </a>
                {%- else -%}
                  <a href="{{ collection.url }}" class="block" aria-label="{{ item_title | escape }}">
                    <div class="flex h-64 w-full items-center justify-center bg-gradient-to-br from-gray-100 to-gray-200">
                      <span class="text-gray-400">{{ item_title }}</span>
                    </div>
                  </a>
                {%- endif -%}

                <!-- Overlay Content -->
                <div class="absolute inset-0 flex flex-col items-center justify-center bg-black/40 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                  <h3 class="mb-3 text-xl font-bold text-white">{{ item_title }}</h3>
                  {%- if block.settings.button_label != blank -%}
                    <span class="inline-block rounded-full bg-white px-6 py-2 text-sm font-semibold text-gray-900 transition-colors duration-300 hover:bg-gray-100">
                      {{ block.settings.button_label }}
                    </span>
                  {%- endif -%}
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>

      <!-- Navigation Arrows -->
      {%- if section.settings.show_arrows and section.blocks.size > section.settings.items_per_view -%}
        <button
          class="absolute left-0 top-1/2 z-10 -translate-y-1/2 -translate-x-1/2 rounded-full bg-white p-3 shadow-lg transition-all duration-300 hover:bg-gray-100 hover:scale-110 disabled:opacity-30 disabled:cursor-not-allowed"
          @click="prev()"
          :disabled="canScrollPrev === false"
          aria-label="Previous items"
        >
          <svg class="h-5 w-5 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
        </button>
        <button
          class="absolute right-0 top-1/2 z-10 -translate-y-1/2 translate-x-1/2 rounded-full bg-white p-3 shadow-lg transition-all duration-300 hover:bg-gray-100 hover:scale-110 disabled:opacity-30 disabled:cursor-not-allowed"
          @click="next()"
          :disabled="canScrollNext === false"
          aria-label="Next items"
        >
          <svg class="h-5 w-5 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </button>
      {%- endif -%}
    </div>
  </div>
</section>

<script>
  document.addEventListener('alpine:init', () => {
    Alpine.data('shoppedByGoldCarousel', (config) => ({
      currentIndex: 0,
      itemsPerView: config.itemsPerView,
      itemsPerViewMobile: config.itemsPerViewMobile,
      autoplay: config.autoplay,
      autoplaySpeed: config.autoplaySpeed,
      interval: null,
      totalItems: {{ section.blocks.size }},

      get itemWidth() {
        return 100 / this.itemsPerView;
      },

      get currentPosition() {
        return this.currentIndex * this.itemWidth;
      },

      get canScrollPrev() {
        return this.currentIndex > 0;
      },

      get canScrollNext() {
        return this.currentIndex < this.totalItems - this.itemsPerView;
      },

      get mobileItemsPerView() {
        return this.itemsPerViewMobile;
      },

      init() {
        // Handle responsive items per view
        this.handleResize();
        window.addEventListener('resize', () => this.handleResize());

        if (this.autoplay && this.totalItems > this.itemsPerView) {
          this.startAutoplay();
        }
      },

      handleResize() {
        if (window.innerWidth < 768) {
          this.itemsPerView = this.mobileItemsPerView;
        } else {
          this.itemsPerView = config.itemsPerView;
        }
        
        // Adjust current index if needed
        const maxIndex = Math.max(0, this.totalItems - this.itemsPerView);
        if (this.currentIndex > maxIndex) {
          this.currentIndex = maxIndex;
        }
      },

      startAutoplay() {
        this.interval = setInterval(() => {
          this.next();
        }, this.autoplaySpeed * 1000);
      },

      pause() {
        if (this.interval) {
          clearInterval(this.interval);
          this.interval = null;
        }
      },

      resume() {
        if (this.autoplay && this.totalItems > this.itemsPerView) {
          this.startAutoplay();
        }
      },

      next() {
        const maxIndex = this.totalItems - this.itemsPerView;
        if (this.currentIndex < maxIndex) {
          this.currentIndex++;
        } else {
          this.currentIndex = 0; // Loop back to start
        }
      },

      prev() {
        if (this.currentIndex > 0) {
          this.currentIndex--;
        } else {
          this.currentIndex = this.totalItems - this.itemsPerView;
        }
      }
    }))
  })
</script>

{% stylesheet %}
  .shopped-by-gold-section {
    overflow: hidden;
  }

  .carousel-track {
    will-change: transform;
  }

  @media (max-width: 768px) {
    .carousel-item {
      padding-left: 0.5rem;
      padding-right: 0.5rem;
    }
  }
{% endstylesheet %}
