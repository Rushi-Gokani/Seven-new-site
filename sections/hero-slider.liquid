{% schema %}
{
  "name": "Hero Slider",
  "class": "section-hero-slider",
  "tag": "section",
  "settings": [
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Autoplay speed",
      "default": 5
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable autoplay",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show navigation arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show pagination dots",
      "default": true
    },
    {
      "type": "select",
      "id": "height",
      "label": "Slider height",
      "options": [
        { "value": "h-[400px] md:h-[500px]", "label": "Medium" },
        { "value": "h-[500px] md:h-[600px]", "label": "Large" },
        { "value": "h-[600px] md:h-[700px]", "label": "Extra large" },
        { "value": "h-[80vh]", "label": "Full viewport" }
      ],
      "default": "h-[500px] md:h-[600px]"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile background image (optional)"
        },
        {
          "type": "url",
          "id": "slide_link",
          "label": "Slide link"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "min": 0,
          "max": 80,
          "step": 10,
          "unit": "%",
          "label": "Overlay opacity",
          "default": 0
        }
      ]
    },
    {
      "type": "promo_toast",
      "name": "Promo Toast",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Small product image"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Promo text",
          "default": "Free Mini Santal Deodorant on orders $65+"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Promo link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Slider",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}

<section
  class="hero-slider relative overflow-hidden group {{ section.settings.height }}"
  x-data="{ 
    currentSlide: 0,
    slideCount: {{ section.blocks.size }},
    autoplay: {{ section.settings.autoplay }},
    autoplaySpeed: {{ section.settings.autoplay_speed }},
    interval: null,
    
    init() {
      if (this.autoplay && this.slideCount > 1) {
        this.startAutoplay()
      }
    },
    startAutoplay() {
      this.interval = setInterval(() => { this.next() }, this.autoplaySpeed * 1000)
    },
    pause() { if (this.interval) clearInterval(this.interval) },
    resume() { if (this.autoplay && this.slideCount > 1) this.startAutoplay() },
    next() { this.currentSlide = (this.currentSlide + 1) % this.slideCount },
    prev() { this.currentSlide = (this.currentSlide - 1 + this.slideCount) % this.slideCount },
    goTo(index) { this.currentSlide = index }
  }"
  x-init="init()"
  @mouseenter="pause()"
  @mouseleave="resume()"
>
  <div class="slides-container relative h-full w-full">
    {%- for block in section.blocks -%}
      <div
        class="slide absolute inset-0 h-full w-full transition-all duration-1000 ease-in-out"
        :class="{ 'opacity-100 z-10': currentSlide === {{ forloop.index0 }}, 'opacity-0 z-0': currentSlide !== {{ forloop.index0 }} }"
        {{ block.shopify_attributes }}
      >
        {%- if block.settings.slide_link != blank -%}
          <a href="{{ block.settings.slide_link }}" class="absolute inset-0 z-20"></a>
        {%- endif -%}

        {%- if block.settings.image != blank -%}
          <picture class="absolute inset-0 h-full w-full">
            {%- if block.settings.mobile_image != blank -%}
              <source
                media="(max-width: 768px)"
                srcset="{{ block.settings.mobile_image | image_url: width: 375 }} 375w,
                        {{ block.settings.mobile_image | image_url: width: 550 }} 550w,
                        {{ block.settings.mobile_image | image_url: width: 768 }} 768w"
                sizes="100vw">
            {%- endif -%}
            <img
              src="{{ block.settings.image | image_url: width: 1920 }}"
              srcset="{{ block.settings.image | image_url: width: 768 }} 768w,
                      {{ block.settings.image | image_url: width: 1024 }} 1024w,
                      {{ block.settings.image | image_url: width: 1366 }} 1366w,
                      {{ block.settings.image | image_url: width: 1920 }} 1920w"
              sizes="100vw"
              alt="{{ block.settings.image.alt | escape }}"
              class="h-full w-full object-cover"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              fetchpriority="{% if forloop.first %}high{% else %}low{% endif %}"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
            >
          </picture>
          
          {%- if block.settings.overlay_opacity > 0 -%}
            <div class="absolute inset-0 z-10 bg-black" style="opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }}"></div>
          {%- endif -%}
        {%- else -%}
          <div class="absolute inset-0 h-full w-full bg-[#f8f8f8]"></div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>

  {%- if section.settings.show_arrows and section.blocks.size > 1 -%}
    <button
      class="nav-arrow absolute left-4 top-1/2 z-30 flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-white/10 text-white backdrop-blur-sm transition-all duration-300 hover:bg-white hover:text-black md:left-10 opacity-0 group-hover:opacity-100"
      @click="prev()"
      aria-label="Previous slide"
    >
      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"></path>
      </svg>
    </button>
    <button
      class="nav-arrow absolute right-4 top-1/2 z-30 flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-white/10 text-white backdrop-blur-sm transition-all duration-300 hover:bg-white hover:text-black md:right-10 opacity-0 group-hover:opacity-100"
      @click="next()"
      aria-label="Next slide"
    >
      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"></path>
      </svg>
    </button>
  {%- endif -%}

  {%- if section.settings.show_dots and section.blocks.size > 1 -%}
    <div class="dots-container absolute bottom-10 left-1/2 -translate-x-1/2 z-30 flex gap-3">
      {%- for block in section.blocks -%}
        <button
          class="h-1 w-10 transition-all duration-500 rounded-full"
          :class="currentSlide === {{ forloop.index0 }} ? 'bg-white' : 'bg-white/30'"
          @click="goTo({{ forloop.index0 }})"
          aria-label="Go to slide {{ forloop.index }}"
        ></button>
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- comment -%} Promo Toast Component {%- endcomment -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'promo_toast' -%}
      <div 
        x-data="{ show: true }" 
        x-show="show" 
        x-transition:enter="transition ease-out duration-500"
        x-transition:enter-start="opacity-0 translate-y-4"
        x-transition:enter-end="opacity-100 translate-y-0"
        class="absolute bottom-6 right-6 md:bottom-10 md:right-10 z-40 bg-[#f8f8f8] p-1.5 pr-4 rounded-2xl flex items-center gap-4 shadow-sm border border-black/5"
        {{ block.shopify_attributes }}
      >
        {%- if block.settings.image != blank -%}
          <div class="h-16 w-16 flex-shrink-0 bg-white rounded-xl overflow-hidden">
            <img 
              src="{{ block.settings.image | image_url: width: 150 }}" 
              alt="{{ block.settings.text }}"
              class="h-full w-full object-contain mix-blend-multiply"
              width="64"
              height="64"
            >
          </div>
        {%- endif -%}
        
        <div class="flex-grow">
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="text-[14px] font-bold text-black hover:underline tracking-tight">
              {{ block.settings.text }}
            </a>
          {%- else -%}
             <span class="text-[14px] font-bold text-black tracking-tight">{{ block.settings.text }}</span>
          {%- endif -%}
        </div>

        <button 
          @click="show = false" 
          class="p-2 ml-2 text-black hover:opacity-50 transition-opacity"
          aria-label="Close promo"
        >
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M1 1L13 13" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
            <path d="M13 1L1 13" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    {%- endif -%}
  {%- endfor -%}
</section>
