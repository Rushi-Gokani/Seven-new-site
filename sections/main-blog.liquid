{% schema %}
  {
    "name": "Main blog",
    "class": "section-main-blog",
    "tag": "section",
    "settings": [
      {
        "type": "header",
        "content": "Layout"
      },
      {
        "type": "range",
        "id": "articles_per_page",
        "min": 3,
        "max": 24,
        "step": 3,
        "label": "Articles per page",
        "default": 9
      },
      {
        "type": "checkbox",
        "id": "show_blog_heading",
        "label": "Show blog heading",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_tags",
        "label": "Show tag filters",
        "default": true
      },
      {
        "type": "header",
        "content": "Article cards"
      },
      {
        "type": "checkbox",
        "id": "show_image",
        "label": "Show featured image",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_date",
        "label": "Show publish date",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_author",
        "label": "Show author",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_excerpt",
        "label": "Show excerpt",
        "default": true
      },
      {
        "type": "range",
        "id": "excerpt_words",
        "min": 10,
        "max": 60,
        "step": 5,
        "label": "Excerpt length (words)",
        "default": 25
      }
    ]
  }
{% endschema %}

{%- paginate blog.articles by section.settings.articles_per_page -%}
  <div class="px-6 py-12 md:px-8 md:py-16">
    <div class="container">
      {% if section.settings.show_blog_heading %}
        <header class="mx-auto mb-10 max-w-3xl text-center md:mb-12">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Blog</p>
          <h1 class="mt-2 text-3xl font-semibold text-slate-900 md:text-4xl">{{ blog.title }}</h1>
          {% if blog.description != blank %}
            <p class="mt-3 text-sm text-slate-600 md:text-base">{{ blog.description }}</p>
          {% endif %}
        </header>
      {% endif %}

      {% if section.settings.show_tags and blog.all_tags.size > 0 %}
        <div class="mb-8 flex flex-wrap justify-center gap-2">
          <a
            href="{{ blog.url }}"
            class="inline-flex items-center rounded-full border px-4 py-1.5 text-sm transition {% if current_tags == blank %}border-slate-900 bg-slate-900 text-white{% else %}border-slate-300 text-slate-700 hover:border-slate-900 hover:text-slate-900{% endif %}"
          >
            All
          </a>
          {% for tag in blog.all_tags %}
            <a
              href="{{ blog.url }}/tagged/{{ tag | handleize }}"
              class="inline-flex items-center rounded-full border px-4 py-1.5 text-sm transition {% if current_tags contains tag %}border-slate-900 bg-slate-900 text-white{% else %}border-slate-300 text-slate-700 hover:border-slate-900 hover:text-slate-900{% endif %}"
            >
              {{ tag }}
            </a>
          {% endfor %}
        </div>
      {% endif %}

      {% if blog.articles_count > 0 %}
        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {% for article in blog.articles %}
            <article class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
              {% if section.settings.show_image and article.image %}
                <a href="{{ article.url }}" class="block overflow-hidden">
                  <img
                    src="{{ article.image | image_url: width: 900 }}"
                    srcset="{{ article.image | image_url: width: 400 }} 400w,
                            {{ article.image | image_url: width: 600 }} 600w,
                            {{ article.image | image_url: width: 900 }} 900w"
                    sizes="(max-width: 768px) 100vw, (max-width: 1280px) 50vw, 33vw"
                    alt="{{ article.image.alt | default: article.title | escape }}"
                    class="h-52 w-full object-cover transition duration-300 hover:scale-[1.03]"
                    loading="{% if forloop.index <= 3 %}eager{% else %}lazy{% endif %}"
                    decoding="async"
                    width="{{ article.image.width }}"
                    height="{{ article.image.height }}"
                  >
                </a>
              {% endif %}

              <div class="p-5">
                {% if section.settings.show_date or section.settings.show_author %}
                  <p class="mb-3 text-xs uppercase tracking-[0.12em] text-slate-500">
                    {% if section.settings.show_date %}
                      <span>{{ article.published_at | date: '%b %d, %Y' }}</span>
                    {% endif %}
                    {% if section.settings.show_date and section.settings.show_author %}
                      <span class="mx-1">-</span>
                    {% endif %}
                    {% if section.settings.show_author %}
                      <span>{{ article.author }}</span>
                    {% endif %}
                  </p>
                {% endif %}

                <h2 class="text-xl font-semibold leading-tight text-slate-900">
                  <a href="{{ article.url }}" class="transition hover:text-indigo-900">{{ article.title }}</a>
                </h2>

                {% if section.settings.show_excerpt %}
                  <p class="mt-3 text-sm leading-6 text-slate-600">
                    {{ article.excerpt_or_content | strip_html | truncatewords: section.settings.excerpt_words }}
                  </p>
                {% endif %}

                <a href="{{ article.url }}" class="mt-4 inline-flex text-sm font-semibold text-indigo-900 no-underline transition hover:text-indigo-700">
                  Read article
                </a>
              </div>
            </article>
          {% endfor %}
        </div>

        <div class="mt-10">
          {% render 'pagination-navigation', paginate: paginate %}
        </div>
      {% else %}
        <div class="rounded-2xl border border-dashed border-slate-300 bg-white p-10 text-center">
          <h2 class="text-2xl font-semibold text-slate-900">No articles published yet</h2>
          <p class="mt-2 text-sm text-slate-600">Add your first post in the Shopify admin to populate this blog page.</p>
        </div>
      {% endif %}
    </div>
  </div>
{%- endpaginate -%}
