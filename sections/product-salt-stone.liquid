     JAVASCRIPT - Alpine Data
=========================================== {% endcomment %}
<script>
  document.addEventListener('alpine:init', () => {
    Alpine.data('productPageSaltStone', (imageCount) => ({
      activeIndex: 0,
      totalImages: imageCount,
      selectedVariant: {{ current_variant.id | json }},
      selectedVariantTitle: {{ current_variant.title | json }},
      quantity: 1,
      isAddingToCart: false,
      showFloatingBadge: true,
      
      get isSoldOut() {
        const variants = JSON.parse(document.querySelector('[data-product-variants]').textContent);
        const variant = variants.find(v => v.id === this.selectedVariant);
        return variant ? !variant.available : true;
      },
      
      get isWaitlist() {
        const variants = JSON.parse(document.querySelector('[data-product-variants]').textContent);
        const variant = variants.find(v => v.id === this.selectedVariant);
        return variant && variant.inventory_policy === 'continue' && variant.inventory_quantity <= 0;
      },
      
      get isVariantAvailable() {
        const variants = JSON.parse(document.querySelector('[data-product-variants]').textContent);
        const variant = variants.find(v => v.id === this.selectedVariant);
        return variant ? variant.available : false;
      },
      
      goToSlide(index) {
        this.activeIndex = index;
        const gallery = this.$refs.mainGallery;
        const slideWidth = gallery.offsetWidth;
        gallery.scrollTo({
          left: slideWidth * index,
          behavior: 'smooth'
        });
        
        // Update thumbnail states
        document.querySelectorAll('.product-thumbnail').forEach((thumb, i) => {
          thumb.classList.toggle('is-active', i === index);
        });
      },
      
      updateActiveFromScroll() {
        const gallery = this.$refs.mainGallery;
        const scrollLeft = gallery.scrollLeft;
        const slideWidth = gallery.offsetWidth;
        const newIndex = Math.round(scrollLeft / slideWidth);
        
        if (newIndex !== this.activeIndex) {
          this.activeIndex = newIndex;
          document.querySelectorAll('.product-thumbnail').forEach((thumb, i) => {
            thumb.classList.toggle('is-active', i === newIndex);
          });
        }
      },
      
      selectVariant(id, title) {
        this.selectedVariant = id;
        this.selectedVariantTitle = title;
        
        // Update URL without reload
        const url = new URL(window.location);
        url.searchParams.set('variant', id);
        window.history.replaceState({}, '', url);
        
        // Update form input
        const formInput = document.querySelector('input[name="id"]');
        if (formInput) formInput.value = id;
        
        // Sync thumbnail to variant media
        try {
          const mediaMap = JSON.parse(document.querySelector('[data-variant-media-map]').textContent);
          if (mediaMap[id]) {
            const mediaIndex = Array.from(document.querySelectorAll('.product-media-slide')).findIndex(
              slide => slide.dataset.mediaId == mediaMap[id]
            );
            if (mediaIndex !== -1) {
              this.goToSlide(mediaIndex);
            }
          }
        } catch (e) {
          console.log('Media map not available');
        }
      },
      
      formatMoney(cents) {
        return '$' + (cents / 100).toFixed(2);
      },
      
      init() {
        // Check if variant is in URL
        const urlParams = new URLSearchParams(window.location.search);
        const variantId = urlParams.get('variant');
        if (variantId) {
          const variants = JSON.parse(document.querySelector('[data-product-variants]').textContent);
          const variant = variants.find(v => v.id == variantId);
          if (variant) {
            this.selectedVariant = parseInt(variantId);
            this.selectedVariantTitle = variant.title;
          }
        }
        
        // Handle form submission
        const form = document.getElementById('product-form-{{ section.id }}');
        if (form) {
          form.addEventListener('submit', (e) => {
            e.preventDefault();
            this.isAddingToCart = true;
            
            const formData = new FormData(form);
            
            fetch('/cart/add.js', {
              method: 'POST',
              body: formData
            })
            .then(response => {
              if (!response.ok) throw new Error('Network response was not ok');
              return response.json();
            })
            .then(data => {
              // Dispatch cart update event
              document.dispatchEvent(new CustomEvent('cart:updated', { detail: data }));
              
              // Show success feedback
              const btn = form.querySelector('.add-to-cart-btn');
              const originalText = btn.textContent;
              btn.textContent = 'ADDED!';
              setTimeout(() => {
                btn.textContent = originalText;
              }, 2000);
            })
            .catch(error => {
              console.error('Error:', error);
              alert('There was an error adding to cart. Please try again.');
            })
            .finally(() => {
              this.isAddingToCart = false;
            });
          });
        }
      }
    }));
  });
</script>
