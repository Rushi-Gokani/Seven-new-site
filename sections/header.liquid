{% schema %}
  {
    "name": "Header",
    "class": "section-header sticky top-0 z-50 border-b border-gray-100",
    "tag": "header",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      },
      {
        "type": "range",
        "id": "logo_max_width",
        "min": 50,
        "max": 300,
        "step": 10,
        "default": 150,
        "unit": "px",
        "label": "Logo width"
      },
      {
        "type": "link_list",
        "id": "navigation_menu",
        "label": "Menu"
      },
      {
        "type": "paragraph",
        "content": "Header content is managed through your store navigation and theme settings."
      }
    ]
  }
{% endschema %}

{% if settings.show_promo_bar %}
  {% render 'promo-bar' %}
{% endif %}

{% liquid
  assign navigation_menu = section.settings.navigation_menu

  if navigation_menu == blank
    assign navigation_menu = linklists['main-menu']
  endif
%}

<div class="relative bg-white px-6 md:px-12 transition-colors duration-300" x-data @keydown.escape.window="$store.global.closeMobileMenu()" x-on:click.outside="$store.global.closeMobileMenu()">
  <div class="mx-auto flex h-16 items-center justify-between text-black font-bold text-[11px] tracking-[0.15em] relative">
    <nav
      aria-label="Mobile navigation"
      class="block md:hidden [[x-cloak]]:hidden"
      id="mobile-nav"
      x-cloak>
      <button
        id="mobile-nav-trigger"
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full border-0 bg-white/10 text-white transition-colors duration-200 hover:bg-white/20 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
        @click="$store.global.toggleMobileMenu()"
        :aria-expanded="$store.global.isMobileMenuVisible"
        aria-label="Toggle mobile menu"
        aria-controls="mobile-menu-panel"
        x-data>
        <span class="sr-only">Menu</span>
        <span aria-hidden="true" class="text-black">
          {% render 'icon-hamburger' %}
        </span>
      </button>
    </nav>

    <!-- Left Navigation (Desktop) -->
    <div class="hidden md:block">
      {% render 'header-menu', menu: navigation_menu %}
    </div>
    <div class="flex items-center justify-start md:hidden">
      <!-- Mobile trigger handled above -->
    </div>

    <!-- Center Logo -->
    <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2">
      <a href="{{ routes.root_url }}" aria-label="{{ shop.name }} home" class="header-logo block text-[11px] md:text-lg lg:text-xl font-medium tracking-[0.2em] uppercase text-black no-underline whitespace-nowrap">
        {% if section.settings.logo %}
          {% assign logo_width = section.settings.logo_max_width %}
          {% assign logo_height = logo_width | times: section.settings.logo.height | divided_by: section.settings.logo.width %}
          <img
            src="{{ section.settings.logo | image_url: width: logo_width }}"
            srcset="{{ section.settings.logo | image_url: width: logo_width }} 1x,
                    {{ section.settings.logo | image_url: width: logo_width | times: 2 }} 2x"
            alt="{{ shop.name }}"
            width="{{ logo_width }}"
            height="{{ logo_height }}"
            loading="eager"
            fetchpriority="high"
            class="object-contain"
            style="max-width: {{ logo_width }}px;"
          >
        {% else %}
          <span>{{ shop.name }}</span>
        {% endif %}
      </a>
    </div>

    <!-- Right Navigation (Desktop/Mobile) -->
    <div class="flex items-center justify-end gap-4 md:gap-6 uppercase">
      {% if settings.enable_predictive_search %}
        <button
          type="button"
          class="hidden md:block hover:opacity-70 transition-opacity focus-visible:outline-none"
          @click="$store.global.isPredictiveSearchVisible = true"
          :aria-expanded="$store.global.isPredictiveSearchVisible ? 'true' : 'false'"
          aria-label="Search"
          aria-controls="predictive-search">
          SEARCH
        </button>
      {% else %}
        <a href="{{ routes.search_url }}" class="hidden md:block hover:opacity-70">SEARCH</a>
      {% endif %}

      {% if shop.customer_accounts_enabled %}
        <a href="{{ routes.account_url }}" class="hidden md:block hover:opacity-70 transition-opacity">
          ACCOUNT
        </a>
      {% endif %}

      <a
        href="{{ routes.cart_url }}"
        class="hidden md:block hover:opacity-70 transition-opacity [[x-cloak]]:hidden"
        @click.prevent="$store.global.isMinicartVisible = true"
        x-cloak>
        BAG
      </a>
    </div>


  {% comment %}
    // Output customer login links

    <ul>
    {% if shop.customer_accounts_enabled %}
    {% if customer %}
    <a href="{{ routes.account_url }}">
    {{ 'action.account' | t }}
    </a>
    {{ 'action.log_out' | t | customer_logout_link }}
    {% else %}
    {{ 'action.log_in' | t | customer_login_link }}
    {{ 'action.register' | t | customer_register_link }}
    {% endif %}
    {% endif %}
    </ul>
  {% endcomment %}
  </div>

  <div
    id="mobile-menu-panel"
    class="absolute left-0 right-0 top-full z-50 bg-white px-4 h-[calc(100vh-4rem)] overflow-y-auto border-t border-gray-100 md:hidden [[x-cloak]]:hidden text-black"
    x-show="$store.global.isMobileMenuVisible"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="opacity-0 -translate-y-4 scale-95"
    x-transition:enter-end="opacity-100 translate-y-0 scale-100"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="opacity-100 translate-y-0 scale-100"
    x-transition:leave-end="opacity-0 -translate-y-2 scale-95"
    x-cloak>
    <div class="py-2">
      {% render 'mobile-menu', menu: navigation_menu %}
    </div>
    <div class="border-t border-white/10 px-4 py-4">
      <a
        href="{{ routes.all_products_collection_url }}"
        class="flex items-center justify-center gap-2 rounded-lg bg-black/5 px-6 py-3 text-sm font-bold uppercase tracking-widest text-black no-underline transition-all duration-300 hover:bg-black hover:text-white"
        @click="$store.global.closeMobileMenu()"
      >
        <span>Shop All</span>
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>
  </div>

</div>
