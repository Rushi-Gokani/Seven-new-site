{% schema %}
  {
    "name": "Header",
    "class": "section-header sticky top-0 z-50 border-b border-gray-100",
    "tag": "header",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      },
      {
        "type": "range",
        "id": "logo_max_width",
        "min": 50,
        "max": 300,
        "step": 10,
        "default": 150,
        "unit": "px",
        "label": "Logo width"
      },
      {
        "type": "link_list",
        "id": "navigation_menu",
        "label": "Menu"
      },
      {
        "type": "paragraph",
        "content": "Header content is managed through your store navigation and theme settings."
      }
    ]
  }
{% endschema %}

{% if settings.show_promo_bar %}
  {% render 'promo-bar' %}
{% endif %}

{% liquid
  assign navigation_menu = section.settings.navigation_menu

  if navigation_menu == blank
    assign navigation_menu = linklists['main-menu']
  endif
%}

<div class="relative bg-white px-6 md:px-12 transition-colors duration-300" x-data @keydown.escape.window="$store.global.closeMobileMenu()" x-on:click.outside="$store.global.closeMobileMenu()">
  <div class="mx-auto flex h-16 items-center justify-between text-black font-bold text-[11px] tracking-[0.15em] relative">
    <!-- Left Navigation (Mobile: Hamburger + Search | Desktop: Empty for centering) -->
    <div class="flex items-center gap-4 md:hidden">
      <nav
        aria-label="Mobile navigation"
        class="block md:hidden [[x-cloak]]:hidden"
        id="mobile-nav"
        x-cloak>
        <button
          id="mobile-nav-trigger"
          type="button"
          class="inline-flex h-10 -ml-4 items-center justify-start pl-0 pr-4 border-0 bg-white/10 text-white transition-colors duration-200 hover:bg-white/20 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
          @click="$store.global.toggleMobileMenu()"
          :aria-expanded="$store.global.isMobileMenuVisible"
          aria-label="Toggle mobile menu"
          aria-controls="mobile-menu-panel"
          x-data>
          <span class="sr-only">Menu</span>
          <span aria-hidden="true" class="text-black">
            {% render 'icon-hamburger' %}
          </span>
        </button>
      </nav>

      <!-- Mobile Search Icon (Left) -->
      <button
        type="button"
        class="md:hidden hover:opacity-70 transition-opacity focus-visible:outline-none bg-transparent border-none p-0 flex items-center -ml-3"
        @click="$store.global.isPredictiveSearchVisible = true"
        aria-label="Search">
        <span class="w-5 h-5 flex items-center justify-center">
          {% render 'icon-search' %}
        </span>
      </button>
    </div>

    <!-- Left Navigation (Desktop) -->
    <div class="hidden md:block">
      {% render 'header-menu', menu: navigation_menu %}
    </div>

    <!-- Center Logo -->
    <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 pl-0 pr-4 md:px-0">
      <a href="{{ routes.root_url }}" aria-label="{{ shop.name }} home" class="header-logo block text-[11px] md:text-lg lg:text-xl font-medium tracking-[0.2em] uppercase text-black no-underline whitespace-nowrap">
        {% if section.settings.logo %}
          {% assign logo_width = section.settings.logo_max_width %}
          {% assign logo_height = logo_width | times: section.settings.logo.height | divided_by: section.settings.logo.width %}
          <img
            src="{{ section.settings.logo | image_url: width: logo_width }}"
            srcset="{{ section.settings.logo | image_url: width: logo_width }} 1x,
                    {{ section.settings.logo | image_url: width: logo_width | times: 2 }} 2x"
            alt="{{ shop.name }}"
            width="{{ logo_width }}"
            height="{{ logo_height }}"
            loading="eager"
            fetchpriority="high"
            class="object-contain"
            style="max-width: {{ logo_width }}px;"
          >
        {% else %}
          <span>{{ shop.name }}</span>
        {% endif %}
      </a>
    </div>

    <!-- Right Navigation (Desktop/Mobile Icons) -->
    <div class="flex items-center justify-end gap-4 md:gap-6 uppercase">
      <!-- Desktop Search -->
      {% if settings.enable_predictive_search %}
        <button
          type="button"
          class="hidden md:block hover:opacity-70 transition-opacity focus-visible:outline-none bg-transparent border-none p-0"
          @click="$store.global.isPredictiveSearchVisible = true"
          :aria-expanded="$store.global.isPredictiveSearchVisible ? 'true' : 'false'"
          aria-label="Search"
          aria-controls="predictive-search">
          SEARCH
        </button>
      {% else %}
        <a href="{{ routes.search_url }}" class="hidden md:block hover:opacity-70 bg-transparent">SEARCH</a>
      {% endif %}

      <!-- Mobile Account Icon -->
      {% if shop.customer_accounts_enabled %}
        <a href="{{ routes.account_url }}" class="md:hidden hover:opacity-70 transition-opacity flex items-center" aria-label="Account">
          <span class="w-5 h-5 flex items-center justify-center">
            {% render 'icon-user' %}
          </span>
        </a>
        <!-- Desktop Account Text -->
        <a href="{{ routes.account_url }}" class="hidden md:block hover:opacity-70 transition-opacity">
          ACCOUNT
        </a>
      {% endif %}

      <!-- Mobile Bag Icon -->
      <a
        href="{{ routes.cart_url }}"
        class="md:hidden hover:opacity-70 transition-opacity flex items-center"
        @click.prevent="$store.global.isMinicartVisible = true"
        aria-label="Cart">
        <span class="w-5 h-5 flex items-center justify-center">
          {% render 'icon-cart' %}
        </span>
      </a>
      <!-- Desktop Bag Text -->
      <a
        href="{{ routes.cart_url }}"
        class="hidden md:block hover:opacity-70 transition-opacity [[x-cloak]]:hidden"
        @click.prevent="$store.global.isMinicartVisible = true"
        x-cloak>
        BAG
      </a>
    </div>


  {% comment %}
    // Output customer login links

    <ul>
    {% if shop.customer_accounts_enabled %}
    {% if customer %}
    <a href="{{ routes.account_url }}">
    {{ 'action.account' | t }}
    </a>
    {{ 'action.log_out' | t | customer_logout_link }}
    {% else %}
    {{ 'action.log_in' | t | customer_login_link }}
    {{ 'action.register' | t | customer_register_link }}
    {% endif %}
    {% endif %}
    </ul>
  {% endcomment %}
  </div>

  <!-- Mobile Menu Backdrop -->
  <div
    class="fixed inset-0 bg-black/40 z-[49] md:hidden [[x-cloak]]:hidden"
    x-show="$store.global.isMobileMenuVisible"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    @click="$store.global.closeMobileMenu()"
    x-cloak>
  </div>

  <!-- Mobile Side Drawer -->
  <div
    id="mobile-menu-panel"
    class="fixed inset-y-0 left-0 z-50 bg-white w-[85vw] h-full shadow-2xl md:hidden [[x-cloak]]:hidden text-black flex flex-col"
    x-show="$store.global.isMobileMenuVisible"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="-translate-x-full"
    x-transition:enter-end="translate-x-0"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="translate-x-0"
    x-transition:leave-end="-translate-x-full"
    x-cloak style="width: 85%;">
    
    <!-- Drawer Header -->
    <div class="flex items-center justify-end px-6 pt-6 pb-2 flex-shrink-0">
      <button 
        @click="$store.global.closeMobileMenu()"
        type="button"
        class="w-10 h-10 flex items-center justify-center bg-white text-black hover:opacity-75 transition-opacity"
        aria-label="Close menu">
        {% render 'icon-close-x' %}
      </button>
    </div>

    <!-- Drawer Content -->
    <div class="flex-grow overflow-y-auto px-6 pb-8">
      {% render 'mobile-menu', menu: navigation_menu %}
    </div>

    <!-- Drawer Footer (Secondary) -->
    <div class="p-8 border-t border-gray-100 flex-shrink-0">
      <div class="space-y-6">
        <a href="#" class="flex items-center gap-3 no-underline group">
          <span class="text-[14px] font-normal uppercase tracking-widest text-black">Subscribe</span>
          <span class="border border-black text-black text-[12px] font-medium px-2 py-0.5 rounded-none uppercase tracking-wide flex-shrink-0">Save 15%</span>
        </a>
        <a href="/pages/store-locator" class="block text-[14px] font-normal uppercase tracking-widest text-black no-underline">
          Find a Store
        </a>
      </div>
    </div>
  </div>

</div>
