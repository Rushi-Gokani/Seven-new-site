{% schema %}
{
  "name": "Collection",
  "class": "section-main-collection",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Quick access collections"
    },
    {
      "type": "checkbox",
      "id": "show_collection_pills",
      "label": "Show collection pills",
      "default": true
    },
    {
      "type": "link_list",
      "id": "collection_pills_menu",
      "label": "Collections menu",
      "info": "Create a navigation menu with links to collections. Each menu item becomes a pill."
    },
    {
      "type": "range",
      "id": "pills_speed",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "s",
      "label": "Marquee scroll speed",
      "default": 25
    },
    {
      "type": "header",
      "content": "Collection banner"
    },
    {
      "type": "checkbox",
      "id": "show_collection_image",
      "label": "Show collection image",
      "default": true
    },
    {
      "type": "select",
      "id": "banner_height",
      "label": "Banner height",
      "options": [
        { "value": "h-[200px] md:h-[280px]", "label": "Small" },
        { "value": "h-[280px] md:h-[360px]", "label": "Medium" },
        { "value": "h-[360px] md:h-[450px]", "label": "Large" }
      ],
      "default": "h-[280px] md:h-[360px]"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content position",
      "options": [
        { "value": "items-start", "label": "Top" },
        { "value": "items-center", "label": "Center" },
        { "value": "items-end", "label": "Bottom" }
      ],
      "default": "items-end"
    },
    {
      "type": "header",
      "content": "Products grid"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 48,
      "step": 4,
      "label": "Products per page",
      "default": 24
    },
    {
      "type": "header",
      "content": "Filters and sorting"
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "label": "Enable sorting",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "label": "Enable filtering",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_filter_count",
      "label": "Show filter counts",
      "default": true
    },
    {
      "type": "paragraph",
      "content": "Product card styles are managed in Theme settings -> Product card."
    }
  ]
}
{% endschema %}

{%- liquid
  assign show_collection_image = section.settings.show_collection_image
  assign collection_image = collection.featured_image | default: collection.products.first.featured_image
  assign filters_enabled = false
  if section.settings.enable_filtering and collection.filters != empty
    assign filters_enabled = true
  endif
  assign active_filters_count = 0

  if filters_enabled
    for filter in collection.filters
      if filter.type == 'price_range'
        if filter.min_value.value != nil or filter.max_value.value != nil
          assign active_filters_count = active_filters_count | plus: 1
        endif
      else
        assign active_filters_count = active_filters_count | plus: filter.active_values.size
      endif
    endfor
  endif

  assign has_active_filters = false
  if active_filters_count > 0
    assign has_active_filters = true
  endif
-%}

<div class="collection-page">
  {%- if show_collection_image and collection_image -%}
    <div class="collection-banner relative {{ section.settings.banner_height }} overflow-hidden">
      <img
        src="{{ collection_image | image_url: width: 1920 }}"
        srcset="{{ collection_image | image_url: width: 768 }} 768w,
                {{ collection_image | image_url: width: 1024 }} 1024w,
                {{ collection_image | image_url: width: 1366 }} 1366w,
                {{ collection_image | image_url: width: 1920 }} 1920w"
        sizes="100vw"
        alt="{{ collection.title | escape }}"
        class="h-full w-full object-cover"
        loading="eager"
        fetchpriority="high"
        decoding="sync"
        width="{{ collection_image.width | default: 1920 }}"
        height="{{ collection_image.height | default: 600 }}"
      >
      <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>
      
      <div class="container absolute inset-x-0 bottom-0 flex {{ section.settings.content_position }} px-6 pb-8 md:px-8 md:pb-12">
        <div class="collection-banner__content text-white">
          <nav class="mb-3 flex flex-wrap items-center gap-2 text-sm opacity-80" aria-label="Breadcrumb">
            <a href="{{ routes.root_url }}" class="hover:underline">Home</a>
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
            <a href="{{ routes.collections_url }}" class="hover:underline">Collections</a>
          </nav>
          <h1 class="text-3xl font-bold md:text-4xl lg:text-5xl">{{ collection.title }}</h1>
          {%- if collection.description != blank -%}
            <p class="mt-3 max-w-2xl text-base opacity-90 md:text-lg">{{ collection.description }}</p>
          {%- endif -%}
          <p class="mt-2 text-sm opacity-70">{{ collection.products_count }} {{ collection.products_count | pluralize: 'product', 'products' }}</p>
        </div>
      </div>
    </div>
  {%- else -%}
    <div class="container px-6 pt-12 md:px-8">
      <nav class="mb-4 flex flex-wrap items-center gap-2 text-sm text-gray-500" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}" class="hover:text-cloud-burst-500">Home</a>
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
        <a href="{{ routes.collections_url }}" class="hover:text-cloud-burst-500">Collections</a>
      </nav>
      <div class="mb-8 border-b border-gray-200 pb-8">
        <h1 class="text-3xl font-bold md:text-4xl">{{ collection.title }}</h1>
        {%- if collection.description != blank -%}
          <p class="mt-3 max-w-2xl text-gray-600">{{ collection.description }}</p>
        {%- endif -%}
        <p class="mt-2 text-sm text-gray-500">{{ collection.products_count }} {{ collection.products_count | pluralize: 'product', 'products' }}</p>
      </div>
    </div>
  {%- endif -%}

  {%- liquid
    assign pills_menu = section.settings.collection_pills_menu
    assign show_pills = section.settings.show_collection_pills
  -%}
  {%- if show_pills and pills_menu != blank and pills_menu.links.size > 0 -%}
    <div
      class="collection-pills overflow-hidden border-b border-gray-200"
      x-data="{
        paused: false,
        dragging: false,
        startX: 0,
        scrollPos: 0,
        pause() { this.paused = true },
        resume() { if (!this.dragging) this.paused = false },
        pointerDown(e) {
          this.dragging = true;
          this.paused = true;
          this.startX = e.pageX - this.$refs.track.offsetLeft;
          this.scrollPos = this.$refs.track.scrollLeft;
        },
        pointerMove(e) {
          if (!this.dragging) return;
          e.preventDefault();
          const x = e.pageX - this.$refs.track.offsetLeft;
          this.$refs.track.scrollLeft = this.scrollPos - (x - this.startX);
        },
        pointerUp() {
          this.dragging = false;
          this.paused = false;
        }
      }"
    >
      <div
        x-ref="track"
        class="collection-pills__track flex overflow-x-auto py-3 [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden"
        :class="dragging ? 'cursor-grabbing select-none [animation-play-state:paused]' : 'cursor-grab'"
        :style="paused ? 'animation-play-state: paused' : ''"
        style="--pills-speed: {{ section.settings.pills_speed }}s"
        @mouseenter="pause()"
        @mouseleave="resume()"
        @pointerdown="pointerDown($event)"
        @pointermove="pointerMove($event)"
        @pointerup="pointerUp()"
        @pointerleave="pointerUp()"
      >
        {%- for i in (1..2) -%}
          <div class="collection-pills__group flex shrink-0 items-center gap-2 px-1" {% if i == 2 %}aria-hidden="true"{% endif %}>
            {%- for link in pills_menu.links -%}
              {%- liquid
                assign is_current = false
                if link.url == collection.url
                  assign is_current = true
                endif
              -%}
              <a
                href="{{ link.url }}"
                class="inline-flex shrink-0 items-center rounded-full border px-4 py-2 text-sm font-medium whitespace-nowrap transition-colors {% if is_current %}border-cloud-burst bg-cloud-burst text-white{% else %}border-gray-200 bg-white text-gray-700 hover:border-gray-300 hover:bg-gray-50{% endif %}"
                {% if is_current %}aria-current="page"{% endif %}
              >
                {{ link.title }}
              </a>
            {%- endfor -%}
          </div>
        {%- endfor -%}
      </div>
    </div>

    <style>
      .collection-pills__track {
        animation: pills-scroll var(--pills-speed, 25s) linear infinite;
      }
      .collection-pills__group {
        min-width: max-content;
      }
      @keyframes pills-scroll {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
      }
      @media (prefers-reduced-motion: reduce) {
        .collection-pills__track { animation: none; }
      }
    </style>
  {%- endif -%}

  <div class="container px-6 py-8 md:px-8">
    <div
      class="collection-toolbar mb-6"
      x-data="{
        filterOpen: false,
        openFilters() {
          this.filterOpen = true;
          document.documentElement.classList.add('overflow-hidden');
        },
        closeFilters() {
          this.filterOpen = false;
          document.documentElement.classList.remove('overflow-hidden');
        }
      }"
      @keydown.escape.window="closeFilters()"
    >
      <div class="flex w-full items-center gap-2 rounded-2xl border border-gray-200 bg-gray-50/70 px-2.5 py-2">
        <div class="flex flex-1 items-center gap-2 overflow-x-auto whitespace-nowrap [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden">
          {%- if filters_enabled -%}
            <button
              type="button"
              class="inline-flex h-10 shrink-0 items-center gap-2 rounded-full border border-gray-300 bg-white px-3.5 text-sm font-medium text-gray-700 transition-colors hover:border-gray-400 hover:bg-white"
              @click="openFilters()"
              aria-controls="collection-filters-drawer"
              :aria-expanded="filterOpen"
            >
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path>
              </svg>
              <span>Filters</span>
              {%- if active_filters_count > 0 -%}
                <span class="inline-flex h-5 min-w-5 items-center justify-center rounded-full bg-cloud-burst px-1.5 text-[11px] font-semibold text-white">
                  {{ active_filters_count }}
                </span>
              {%- endif -%}
            </button>
          {%- endif -%}

          <p class="shrink-0 text-xs font-medium text-gray-500 sm:text-sm">
            {{ collection.products_count }} {{ collection.products_count | pluralize: 'product', 'products' }}
          </p>
        </div>

        {%- if section.settings.enable_sorting -%}
          <form action="{{ collection.url }}" method="get" class="ml-auto flex shrink-0 items-center gap-2">
            {%- if filters_enabled -%}
              {%- for filter in collection.filters -%}
                {%- if filter.type == 'price_range' -%}
                  {%- if filter.min_value.value != nil -%}
                    <input type="hidden" name="{{ filter.min_value.param_name }}" value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}">
                  {%- endif -%}
                  {%- if filter.max_value.value != nil -%}
                    <input type="hidden" name="{{ filter.max_value.param_name }}" value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}">
                  {%- endif -%}
                {%- else -%}
                  {%- for value in filter.active_values -%}
                    <input type="hidden" name="{{ value.param_name }}" value="{{ value.value }}">
                  {%- endfor -%}
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}

            <div
              class="relative shrink-0"
              x-data="{
                open: false,
                selectedValue: '{{ collection.sort_by }}',
                labels: { {%- for option in collection.sort_options -%}'{{ option.value }}': '{{ option.name }}'{% unless forloop.last %}, {% endunless %}{%- endfor -%} },
                get selectedLabel() { return this.labels[this.selectedValue] || 'Sort' },
                toggle() { this.open = !this.open },
                close() { this.open = false },
                select(value) {
                  this.selectedValue = value;
                  this.$refs.sortInput.value = value;
                  this.close();
                  this.$refs.sortInput.form.submit();
                }
              }"
              @click.outside="close()"
              @keydown.escape.window="close()"
            >
              <input type="hidden" name="sort_by" x-ref="sortInput" :value="selectedValue">
              <button
                type="button"
                class="inline-flex h-10 items-center gap-2 rounded-full border border-gray-300 bg-white px-3.5 text-sm font-medium text-gray-700 transition-colors hover:border-gray-400"
                @click="toggle()"
                :aria-expanded="open"
                aria-haspopup="listbox"
                aria-label="Sort by"
              >
                <svg class="h-4 w-4 shrink-0 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4h13M3 8h9m-9 4h6m4 0l4-4m0 0l4 4m-4-4v12"></path>
                </svg>
                <span x-text="selectedLabel"></span>
                <svg class="h-4 w-4 shrink-0 text-gray-400 transition-transform" :class="open && 'rotate-180'" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
              </button>

              <ul
                x-show="open"
                x-transition:enter="transition ease-out duration-150"
                x-transition:enter-start="opacity-0 -translate-y-1"
                x-transition:enter-end="opacity-100 translate-y-0"
                x-transition:leave="transition ease-in duration-100"
                x-transition:leave-start="opacity-100 translate-y-0"
                x-transition:leave-end="opacity-0 -translate-y-1"
                x-cloak
                class="absolute right-0 z-30 mt-2 min-w-[12rem] overflow-hidden rounded-xl border border-gray-200 bg-white py-1 shadow-lg [[x-cloak]]:hidden"
                role="listbox"
                aria-label="Sort options"
              >
                {%- for option in collection.sort_options -%}
                  <li
                    role="option"
                    :aria-selected="selectedValue === '{{ option.value }}'"
                    data-sort-value="{{ option.value }}"
                    class="cursor-pointer px-4 py-2.5 text-sm transition-colors"
                    :class="selectedValue === '{{ option.value }}'
                      ? 'bg-cloud-burst/10 font-semibold text-cloud-burst'
                      : 'text-gray-700 hover:bg-gray-50'"
                    @click="select('{{ option.value }}')"
                  >
                    {{ option.name }}
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          </form>
        {%- endif -%}
      </div>

      {%- if filters_enabled -%}
        <div
          id="collection-filters-drawer"
          class="fixed inset-0 z-40 [[x-cloak]]:hidden"
          x-show="filterOpen"
          x-cloak
          x-transition.opacity
        >
          <button
            type="button"
            class="absolute inset-0 bg-black/40"
            aria-label="Close filters"
            @click="closeFilters()"
          ></button>

          <aside
            class="absolute inset-y-0 right-0 z-10 flex h-full w-full max-w-md flex-col border-l border-gray-200 bg-white"
            role="dialog"
            aria-modal="true"
            aria-label="Collection filters"
            x-transition:enter="transform transition ease-out duration-300"
            x-transition:enter-start="translate-x-full"
            x-transition:enter-end="translate-x-0"
            x-transition:leave="transform transition ease-in duration-200"
            x-transition:leave-start="translate-x-0"
            x-transition:leave-end="translate-x-full"
          >
            <div class="flex items-center justify-between border-b border-gray-200 px-5 py-4">
              <div>
                <h2 class="text-lg font-semibold text-gray-900">Filters</h2>
                <p class="text-xs text-gray-500">
                  {%- if collection.filter_type == 'OR' -%}
                    Products match any selected filter.
                  {%- else -%}
                    Products match all selected filters.
                  {%- endif -%}
                </p>
              </div>
              <button
                type="button"
                class="rounded-full p-2 text-gray-500 transition-colors hover:bg-gray-100 hover:text-gray-700"
                @click="closeFilters()"
                aria-label="Close filters"
              >
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
              </button>
            </div>

            <form action="{{ collection.url }}" method="get" class="flex h-full flex-col">
              {%- if section.settings.enable_sorting and collection.sort_by != blank -%}
                <input type="hidden" name="sort_by" value="{{ collection.sort_by }}">
              {%- endif -%}

              <div class="flex-1 space-y-4 overflow-y-auto px-5 py-4">
                {%- for filter in collection.filters -%}
                  {%- liquid
                    assign filter_has_active_values = false
                    if filter.type == 'price_range'
                      if filter.min_value.value != nil or filter.max_value.value != nil
                        assign filter_has_active_values = true
                      endif
                    elsif filter.active_values.size > 0
                      assign filter_has_active_values = true
                    endif
                  -%}

                  <details class="rounded-lg border border-gray-200 bg-gray-50 p-3" {% if filter_has_active_values %}open{% endif %}>
                    <summary class="flex cursor-pointer list-none items-center justify-between gap-2 text-sm font-semibold text-gray-800 [&::-webkit-details-marker]:hidden">
                      <span>{{ filter.label }}</span>
                      {%- if filter.type == 'price_range' -%}
                        <span class="text-xs text-gray-500">Custom range</span>
                      {%- else -%}
                        <span class="text-xs text-gray-500">{{ filter.values.size }} options</span>
                      {%- endif -%}
                    </summary>

                    <div class="pt-3">
                      {%- if filter.type == 'list' or filter.type == 'boolean' -%}
                        <ul class="max-h-56 space-y-2 overflow-auto pr-1">
                          {%- for value in filter.values -%}
                            {%- assign is_disabled = false -%}
                            {%- if value.count == 0 -%}
                              {%- if value.active == false -%}
                                {%- assign is_disabled = true -%}
                              {%- endif -%}
                            {%- endif -%}
                            <li>
                              <label class="flex items-center gap-2 rounded-md px-1 py-1 text-sm {% if is_disabled %}cursor-not-allowed opacity-60{% else %}cursor-pointer{% endif %}">
                                <input
                                  type="checkbox"
                                  name="{{ value.param_name }}"
                                  value="{{ value.value }}"
                                  {% if value.active %}checked{% endif %}
                                  {% if is_disabled %}disabled{% endif %}
                                  class="h-4 w-4 rounded border-gray-300 text-cloud-burst focus:ring-cloud-burst"
                                >

                                {%- if filter.presentation == 'swatch' and value.swatch != blank -%}
                                  <span class="h-4 w-4 flex-shrink-0 rounded-full border border-gray-300 bg-cover bg-center"
                                    {%- if value.swatch.image != blank -%}
                                      style="background-image: url('{{ value.swatch.image | image_url: width: 32 }}');"
                                    {%- elsif value.swatch.color != blank -%}
                                      style="background-color: {{ value.swatch.color }};"
                                    {%- endif -%}
                                  ></span>
                                {%- endif -%}

                                <span class="flex-1 {% if is_disabled %}text-gray-400{% else %}text-gray-700{% endif %}">{{ value.label }}</span>

                                {%- if section.settings.show_filter_count -%}
                                  <span class="text-xs text-gray-400">{{ value.count }}</span>
                                {%- endif -%}
                              </label>
                            </li>
                          {%- endfor -%}
                        </ul>
                      {%- elsif filter.type == 'price_range' -%}
                        {%- assign range_max = filter.range_max | money_without_currency | replace: ',', '' -%}
                        <div class="grid grid-cols-[auto,1fr] items-center gap-3">
                          <span class="text-sm text-gray-500">Min</span>
                          <div class="relative">
                            <span class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-sm text-gray-400">{{ cart.currency.symbol }}</span>
                            <input
                              type="number"
                              name="{{ filter.min_value.param_name }}"
                              value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"
                              min="0"
                              max="{{ range_max }}"
                              placeholder="0"
                              class="w-full rounded-md border border-gray-300 py-2 pl-7 pr-3 text-sm focus:border-cloud-burst focus:outline-none focus:ring-1 focus:ring-cloud-burst"
                            >
                          </div>

                          <span class="text-sm text-gray-500">Max</span>
                          <div class="relative">
                            <span class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-sm text-gray-400">{{ cart.currency.symbol }}</span>
                            <input
                              type="number"
                              name="{{ filter.max_value.param_name }}"
                              value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"
                              min="0"
                              max="{{ range_max }}"
                              placeholder="{{ range_max }}"
                              class="w-full rounded-md border border-gray-300 py-2 pl-7 pr-3 text-sm focus:border-cloud-burst focus:outline-none focus:ring-1 focus:ring-cloud-burst"
                            >
                          </div>
                        </div>
                      {%- endif -%}
                    </div>
                  </details>
                {%- endfor -%}
              </div>

              <div class="space-y-3 border-t border-gray-200 bg-white px-5 py-4">
                <button
                  type="submit"
                  class="w-full rounded-lg bg-cloud-burst px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-cloud-burst-400"
                >
                  Apply filters
                </button>
                <a href="{{ collection.url }}" class="block w-full rounded-lg border border-gray-300 px-5 py-2.5 text-center text-sm font-medium text-gray-700 transition-colors hover:bg-gray-50">
                  Clear all
                </a>
              </div>
            </form>
          </aside>
        </div>
      {%- endif -%}
    </div>

    {%- if has_active_filters -%}
      <div class="active-filters mb-6 flex flex-wrap items-center gap-2">
        {%- for filter in collection.filters -%}
          {%- if filter.type == 'price_range' -%}
            {%- if filter.min_value.value != nil or filter.max_value.value != nil -%}
              <a href="{{ filter.url_to_remove }}" class="inline-flex items-center gap-1.5 rounded-full bg-gray-100 px-3 py-1.5 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-200">
                {{ filter.label }}:
                {%- if filter.min_value.value -%}{{ filter.min_value.value | money }}{%- else -%}{{ 0 | money }}{%- endif -%}
                -
                {%- if filter.max_value.value -%}{{ filter.max_value.value | money }}{%- else -%}{{ filter.range_max | money }}{%- endif -%}
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
              </a>
            {%- endif -%}
          {%- else -%}
            {%- for value in filter.active_values -%}
              <a href="{{ value.url_to_remove }}" class="inline-flex items-center gap-1.5 rounded-full bg-gray-100 px-3 py-1.5 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-200">
                {{ value.label }}
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
              </a>
            {%- endfor -%}
          {%- endif -%}
        {%- endfor -%}

        <a href="{{ collection.url }}" class="inline-flex items-center rounded-full px-3 py-1.5 text-sm font-medium text-cloud-burst-500 hover:underline">
          Clear all
        </a>
      </div>
    {%- endif -%}

    {%- paginate collection.products by section.settings.products_per_page -%}
      <div
        data-collection-infinite-scroll
        data-section-id="{{ section.id }}"
        data-next-page-url="{% if paginate.next %}{{ paginate.next.url | escape }}{% endif %}"
      >
        {%- if collection.products.size > 0 -%}
          <ul class="product-grid grid grid-cols-2 gap-4 md:grid-cols-4 md:gap-6 lg:gap-8" role="list" data-collection-products-grid>
            {%- for product in collection.products -%}
              <li>
                {%- if forloop.index <= 4 -%}
                  {% render 'product-grid-item', product: product, loading: 'eager', quick_add_variant_selector: true %}
                {%- else -%}
                  {% render 'product-grid-item', product: product, quick_add_variant_selector: true %}
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>

          {%- if paginate.pages > 1 -%}
            <div class="mt-12" data-collection-pagination>
              {% render 'pagination-navigation', paginate: paginate %}
            </div>

            <div
              class="mt-6 hidden items-center justify-center gap-2 text-sm text-gray-500"
              data-collection-infinite-scroll-loading
              role="status"
              aria-live="polite"
              aria-hidden="true"
            >
              <svg class="h-4 w-4 animate-spin" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
              </svg>
              <span>Loading more products...</span>
            </div>

            <p class="mt-4 text-center text-xs text-gray-400" data-collection-infinite-scroll-end hidden>
              You have reached the end of this collection.
            </p>

            <div class="h-px w-full" data-collection-infinite-scroll-sentinel aria-hidden="true"></div>
          {%- endif -%}
        {%- else -%}
          <div class="py-16 text-center">
            <svg class="mx-auto h-16 w-16 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
            </svg>
            <h2 class="mt-4 text-xl font-semibold text-gray-700">No products found</h2>
            <p class="mt-2 text-gray-500">Try adjusting your filters or search.</p>
            <a href="{{ collection.url }}" class="mt-6 inline-block rounded-lg bg-cloud-burst px-6 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-cloud-burst-400">
              Clear filters
            </a>
          </div>
        {%- endif -%}
      </div>
    {%- endpaginate -%}
  </div>
</div>
