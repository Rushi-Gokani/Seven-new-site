{%- liquid
  assign show_collection_image = section.settings.show_collection_image
  assign collection_image = collection.featured_image | default: collection.products.first.featured_image
  assign filters_enabled = false
  if section.settings.enable_filtering and collection.filters != empty
    assign filters_enabled = true
  endif
  assign active_filters_count = 0

  if filters_enabled
    for filter in collection.filters
      if filter.type == 'price_range'
        if filter.min_value.value != nil or filter.max_value.value != nil
          assign active_filters_count = active_filters_count | plus: 1
        endif
      else
        assign active_filters_count = active_filters_count | plus: filter.active_values.size
      endif
    endfor
  endif

  assign has_active_filters = false
  if active_filters_count > 0
    assign has_active_filters = true
  endif
-%}

<div class="collection-page">
  <!-- Collection Header -->
  <div class="collection-header">
    <div class="container mx-auto px-6 py-12 md:px-8 lg:px-12">
      <div class="text-center max-w-4xl mx-auto">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-light tracking-tight text-black mb-4">
          {{ collection.title }}
        </h1>
        {%- if collection.description != blank -%}
          <p class="text-lg md:text-xl text-gray-600 mb-6 max-w-2xl mx-auto">
            {{ collection.description }}
          </p>
        {%- endif -%}
        <p class="text-sm text-gray-500">
          {{ collection.products_count }} {{ collection.products_count | pluralize: 'product', 'products' }}
        </p>
      </div>
    </div>
  </div>

  <!-- Filters and Sorting -->
  <div class="collection-toolbar border-b border-gray-200">
    <div class="container mx-auto px-6 py-6 md:px-8 lg:px-12">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <div class="flex items-center gap-4">
          {%- if filters_enabled -%}
            <button
              type="button"
              class="inline-flex items-center gap-2 px-4 py-2 border border-gray-300 rounded-full text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors"
              onclick="toggleFilters()"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path>
              </svg>
              Filters
              {%- if active_filters_count > 0 -%}
                <span class="ml-2 px-2 py-0.5 text-xs font-semibold bg-black text-white rounded-full">
                  {{ active_filters_count }}
                </span>
              {%- endif -%}
            </button>
          {%- endif -%}
        </div>

        {%- if section.settings.enable_sorting -%}
          <form action="{{ collection.url }}" method="get" class="flex items-center gap-2">
            {%- if filters_enabled -%}
              {%- for filter in collection.filters -%}
                {%- if filter.type == 'price_range' -%}
                  {%- if filter.min_value.value != nil -%}
                    <input type="hidden" name="{{ filter.min_value.param_name }}" value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}">
                  {%- endif -%}
                  {%- if filter.max_value.value != nil -%}
                    <input type="hidden" name="{{ filter.max_value.param_name }}" value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}">
                  {%- endif -%}
                {%- else -%}
                  {%- for value in filter.active_values -%}
                    <input type="hidden" name="{{ value.param_name }}" value="{{ value.value }}">
                  {%- endfor -%}
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}

            <select name="sort_by" onchange="this.form.submit()" class="px-4 py-2 border border-gray-300 rounded-full text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 transition-colors">
              {%- for option in collection.sort_options -%}
                <option value="{{ option.value }}" {% if collection.sort_by == option.value %}selected{% endif %}>
                  {{ option.name }}
                </option>
              {%- endfor -%}
            </select>
          </form>
        {%- endif -%}
      </div>

      {%- if has_active_filters -%}
        <div class="active-filters mt-4 flex flex-wrap items-center gap-2">
          {%- for filter in collection.filters -%}
            {%- if filter.type == 'price_range' -%}
              {%- if filter.min_value.value != nil or filter.max_value.value != nil -%}
                <a href="{{ filter.url_to_remove }}" class="inline-flex items-center gap-1 px-3 py-1 text-sm bg-gray-100 rounded-full text-gray-700 hover:bg-gray-200 transition-colors">
                  {{ filter.label }}:
                  {%- if filter.min_value.value -%}{{ filter.min_value.value | money }}{%- else -%}{{ 0 | money }}{%- endif -%}
                  -
                  {%- if filter.max_value.value -%}{{ filter.max_value.value | money }}{%- else -%}{{ filter.range_max | money }}{%- endif -%}
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                  </svg>
                </a>
              {%- endif -%}
            {%- else -%}
              {%- for value in filter.active_values -%}
                <a href="{{ value.url_to_remove }}" class="inline-flex items-center gap-1 px-3 py-1 text-sm bg-gray-100 rounded-full text-gray-700 hover:bg-gray-200 transition-colors">
                  {{ value.label }}
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                  </svg>
                </a>
              {%- endfor -%}
            {%- endif -%}
          {%- endfor -%}

          <a href="{{ collection.url }}" class="inline-flex items-center px-3 py-1 text-sm text-black hover:underline">
            Clear all
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>

  <!-- Products Grid -->
  <div class="collection-products">
    <div class="container mx-auto px-6 py-12 md:px-8 lg:px-12">
      {%- paginate collection.products by section.settings.products_per_page -%}
        {%- if collection.products.size > 0 -%}
          <div class="product-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" role="list">
            {%- for product in collection.products -%}
              <div class="product-card" {{ block.shopify_attributes }}>
                <!-- Product Image -->
                <div class="product-image-container mb-4">
                  <a href="{{ product.url }}" class="block relative overflow-hidden bg-gray-100 aspect-[3/4]">
                    {%- if product.featured_image -%}
                      <img
                        src="{{ product.featured_image | image_url: width: 600 }}"
                        srcset="{{ product.featured_image | image_url: width: 400 }} 400w,
                                {{ product.featured_image | image_url: width: 600 }} 600w,
                                {{ product.featured_image | image_url: width: 800 }} 800w"
                        sizes="(min-width: 1024px) 400px, (min-width: 768px) 50vw, 100vw"
                        alt="{{ product.featured_image.alt | default: product.title | escape }}"
                        class="w-full h-full object-cover transition-transform duration-700 hover:scale-105"
                        loading="lazy"
                        width="{{ product.featured_image.width }}"
                        height="{{ product.featured_image.height }}"
                      >
                    {%- else -%}
                      <div class="w-full h-full flex items-center justify-center bg-gray-200">
                        <span class="text-gray-400">No image</span>
                      </div>
                    {%- endif -%}

                    <!-- Quick Add Button -->
                    {%- if product.available -%}
                      <div class="absolute bottom-4 left-4 right-4 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                        <button
                          type="button"
                          class="w-full px-4 py-2 bg-black text-white text-sm font-medium rounded-full hover:bg-gray-800 transition-colors"
                          onclick="quickAdd('{{ product.id }}')"
                        >
                          Quick Add
                        </button>
                      </div>
                    {%- endif -%}

                    <!-- Product Badges -->
                    {%- if product.compare_at_price > product.price -%}
                      <div class="absolute top-4 left-4 px-2 py-1 bg-black text-white text-xs font-medium rounded-full">
                        Sale
                      </div>
                    {%- endif -%}
                    {%- unless product.available -%}
                      <div class="absolute top-4 left-4 px-2 py-1 bg-gray-900 text-white text-xs font-medium rounded-full">
                        Sold Out
                      </div>
                    {%- endunless -%}
                  </a>
                </div>

                <!-- Product Info -->
                <div class="product-info">
                  <h3 class="product-title mb-2">
                    <a href="{{ product.url }}" class="text-lg font-light text-black hover:text-gray-600 transition-colors">
                      {{ product.title }}
                    </a>
                  </h3>

                  <div class="product-price mb-4">
                    {%- if product.compare_at_price > product.price -%}
                      <div class="flex items-center gap-2">
                        <span class="text-lg font-medium text-black">{{ product.price | money }}</span>
                        <span class="text-sm text-gray-500 line-through">{{ product.compare_at_price | money }}</span>
                      </div>
                    {%- else -%}
                      <span class="text-lg font-medium text-black">{{ product.price | money }}</span>
                    {%- endif -%}
                  </div>

                  <!-- Product Variants (Color Swatches) -->
                  {%- if product.options contains 'Color' -%}
                    <div class="product-variants mb-4">
                      {%- for color in product.options_by_name['Color'].values limit: 4 -%}
                        <div class="inline-block w-4 h-4 rounded-full border border-gray-300 mr-2" 
                             style="background-color: {{ color | downcase }};">
                        </div>
                      {%- endfor -%}
                      {%- if product.options_by_name['Color'].values.size > 4 -%}
                        <span class="text-xs text-gray-500">+{{ product.options_by_name['Color'].values.size | minus: 4 }}</span>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                </div>
              </div>
            {%- endfor -%}
          </div>

          <!-- Pagination -->
          {%- if paginate.pages > 1 -%}
            <div class="pagination mt-16 flex justify-center">
              <nav class="flex items-center gap-2" role="navigation" aria-label="Pagination">
                {%- if paginate.previous -%}
                  <a href="{{ paginate.previous.url }}" class="px-4 py-2 border border-gray-300 rounded-full text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">
                    Previous
                  </a>
                {%- endif -%}

                {%- for part in paginate.parts -%}
                  {%- if part.is_link -%}
                    <a href="{{ part.url }}" class="px-4 py-2 border border-gray-300 rounded-full text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">
                      {{ part.title }}
                    </a>
                  {%- else -%}
                    <span class="px-4 py-2 bg-black text-white text-sm font-medium rounded-full">
                      {{ part.title }}
                    </span>
                  {%- endif -%}
                {%- endfor -%}

                {%- if paginate.next -%}
                  <a href="{{ paginate.next.url }}" class="px-4 py-2 border border-gray-300 rounded-full text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">
                    Next
                  </a>
                {%- endif -%}
              </nav>
            </div>
          {%- endif -%}

        {%- else -%}
          <div class="empty-state py-16 text-center">
            <div class="max-w-md mx-auto">
              <svg class="w-16 h-16 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
              </svg>
              <h2 class="text-2xl font-light text-black mb-2">No products found</h2>
              <p class="text-gray-600 mb-6">Try adjusting your filters or browse our other collections.</p>
              <a href="{{ collection.url }}" class="inline-block px-6 py-3 bg-black text-white text-sm font-medium rounded-full hover:bg-gray-800 transition-colors">
                Clear filters
              </a>
            </div>
          </div>
        {%- endif -%}
      {%- endpaginate -%}
    </div>
  </div>
</div>

<!-- Filters Drawer (Hidden by default) -->
<div id="filters-drawer" class="fixed inset-0 z-50 hidden">
  <div class="absolute inset-0 bg-black bg-opacity-50" onclick="toggleFilters()"></div>
  <div class="absolute right-0 top-0 h-full w-full max-w-md bg-white shadow-xl">
    <div class="flex items-center justify-between p-6 border-b border-gray-200">
      <h2 class="text-lg font-medium text-black">Filters</h2>
      <button onclick="toggleFilters()" class="p-2 text-gray-500 hover:text-black transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <div class="p-6 overflow-y-auto h-full pb-32">
      <form action="{{ collection.url }}" method="get">
        {%- if section.settings.enable_sorting and collection.sort_by != blank -%}
          <input type="hidden" name="sort_by" value="{{ collection.sort_by }}">
        {%- endif -%}

        {%- for filter in collection.filters -%}
          <div class="mb-8">
            <h3 class="text-sm font-medium text-black mb-4">{{ filter.label }}</h3>
            
            {%- if filter.type == 'list' -%}
              <div class="space-y-3">
                {%- for value in filter.values -%}
                  {%- assign is_disabled = false -%}
                  {%- if value.count == 0 and value.active == false -%}
                    {%- assign is_disabled = true -%}
                  {%- endif -%}
                  
                  <label class="flex items-center gap-3 {% if is_disabled %}opacity-50{% endif %}">
                    <input
                      type="checkbox"
                      name="{{ value.param_name }}"
                      value="{{ value.value }}"
                      {% if value.active %}checked{% endif %}
                      {% if is_disabled %}disabled{% endif %}
                      class="w-4 h-4 border-gray-300 text-black focus:ring-black"
                    >
                    <span class="text-sm text-gray-700">{{ value.label }}</span>
                    {%- if section.settings.show_filter_count -%}
                      <span class="text-xs text-gray-500">({{ value.count }})</span>
                    {%- endif -%}
                  </label>
                {%- endfor -%}
              </div>
            {%- elsif filter.type == 'price_range' -%}
              <div class="space-y-4">
                <div>
                  <label class="text-sm text-gray-700 block mb-2">Min Price</label>
                  <input
                    type="number"
                    name="{{ filter.min_value.param_name }}"
                    value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"
                    min="0"
                    max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                    placeholder="0"
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-black"
                  >
                </div>
                <div>
                  <label class="text-sm text-gray-700 block mb-2">Max Price</label>
                  <input
                    type="number"
                    name="{{ filter.max_value.param_name }}"
                    value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"
                    min="0"
                    max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                    placeholder="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-black"
                  >
                </div>
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}

        <div class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 p-6">
          <div class="flex gap-4">
            <button
              type="submit"
              class="flex-1 px-6 py-3 bg-black text-white text-sm font-medium rounded-lg hover:bg-gray-800 transition-colors"
            >
              Apply Filters
            </button>
            <a href="{{ collection.url }}" class="flex-1 px-6 py-3 border border-gray-300 text-gray-700 text-sm font-medium rounded-lg text-center hover:bg-gray-50 transition-colors">
              Clear All
            </a>
          </div>
        </div>
      </form>
    </div>
  </div>
</div>

<style>
.collection-page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.product-card {
  transition: transform 0.3s ease;
}

.product-card:hover {
  transform: translateY(-4px);
}

.product-image-container {
  position: relative;
  overflow: hidden;
}

.product-image-container a {
  display: block;
}

.product-image-container a:hover img {
  transform: scale(1.05);
}

.product-title a {
  text-decoration: none;
}

@media (max-width: 768px) {
  .product-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
}

@media (max-width: 480px) {
  .product-grid {
    grid-template-columns: 1fr;
  }
}
</style>

<script>
function toggleFilters() {
  const drawer = document.getElementById('filters-drawer');
  drawer.classList.toggle('hidden');
}

function quickAdd(productId) {
  // Implement quick add functionality
  console.log('Quick add product:', productId);
}
</script>

{% schema %}
{
  "name": "Collection",
  "class": "section-main-collection",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Collection Settings"
    },
    {
      "type": "checkbox",
      "id": "show_collection_image",
      "label": "Show collection image",
      "default": false
    },
    {
      "type": "header",
      "content": "Products Grid"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 6,
      "max": 48,
      "step": 6,
      "label": "Products per page",
      "default": 18
    },
    {
      "type": "header",
      "content": "Filters and Sorting"
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "label": "Enable sorting",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "label": "Enable filtering",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_filter_count",
      "label": "Show filter counts",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "featured_product",
      "name": "Featured Product",
      "limit": 1,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "badge_text",
          "label": "Badge text",
          "default": "Featured"
        }
      ]
    }
  ]
}
{% endschema %}
