{%- liquid
  assign heading = section.settings.heading
  assign heading_size = section.settings.heading_size
  assign heading_alignment = section.settings.heading_alignment
  assign products_to_show = section.settings.products_to_show
  assign columns_desktop = section.settings.columns_desktop
  assign show_view_all = section.settings.show_view_all
  assign show_vendor = section.settings.show_vendor
  assign show_quick_add = section.settings.show_quick_add
  assign image_ratio = section.settings.image_ratio
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
-%}

{%- if section.blocks.size > 0 -%}
  <div
    x-data="tabbedCollections()"
    class="px-6 md:px-8"
    style="padding-top: {{ padding_top }}px; padding-bottom: {{ padding_bottom }}px;"
  >
    <div class="container">
      {%- if heading != blank -%}
        <{{ heading_size }} class="mb-8 md:mb-10 {% if heading_alignment == 'center' %}text-center{% endif %}">
          {{- heading -}}
        </{{ heading_size }}>
      {%- endif -%}

      {%- comment -%} Tab Navigation {%- endcomment -%}
      {%- if section.blocks.size > 1 -%}
        <div
          class="mb-8 md:mb-10 {% if heading_alignment == 'center' %}flex justify-center{% endif %}"
          x-ref="tabBar"
          role="tablist"
          aria-label="{{ heading | default: 'Collection tabs' }}"
        >
          <div class="inline-flex gap-2 overflow-x-auto scrollbar-hide max-w-full pb-1">
            {%- for block in section.blocks -%}
              {%- liquid
                assign tab_label = block.settings.tab_label
                if tab_label == blank and block.settings.collection != blank
                  assign tab_label = block.settings.collection.title
                endif
                if tab_label == blank
                  assign tab_label = 'Collection ' | append: forloop.index
                endif
              -%}

              <button
                @click="setTab({{ forloop.index0 }})"
                :class="activeTab === {{ forloop.index0 }}
                  ? 'bg-cloud-burst-500 text-white shadow-sm'
                  : 'bg-gray-100 text-gray-700 hover:bg-gray-200'"
                class="rounded-full px-5 py-2.5 text-sm font-medium whitespace-nowrap transition-all duration-200 cursor-pointer"
                role="tab"
                :aria-selected="(activeTab === {{ forloop.index0 }}).toString()"
                aria-controls="tabpanel-{{ section.id }}-{{ forloop.index0 }}"
                :tabindex="activeTab === {{ forloop.index0 }} ? 0 : -1"
                id="tab-{{ section.id }}-{{ forloop.index0 }}"
              >
                {{- tab_label -}}
              </button>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}

      {%- comment -%} Tab Panels {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- assign collection = block.settings.collection -%}

        <div
          x-show="activeTab === {{ forloop.index0 }}"
          {% unless forloop.first %}x-cloak{% endunless %}
          id="tabpanel-{{ section.id }}-{{ forloop.index0 }}"
          role="tabpanel"
          aria-labelledby="tab-{{ section.id }}-{{ forloop.index0 }}"
          {{ block.shopify_attributes }}
        >
          {%- if collection != blank and collection.products.size > 0 -%}
            {%- comment -%} Desktop Grid {%- endcomment -%}
            <div
              class="hidden md:grid gap-6"
              style="grid-template-columns: repeat({{ columns_desktop }}, minmax(0, 1fr));"
            >
              {%- for product in collection.products limit: products_to_show -%}
                {%- render 'product-grid-item',
                  product: product,
                  show_vendor: show_vendor,
                  show_quick_add: show_quick_add,
                  image_ratio: image_ratio
                -%}
              {%- endfor -%}
            </div>

            {%- comment -%} Mobile Carousel {%- endcomment -%}
            <div class="md:hidden -mx-6 px-6">
              <div class="flex gap-4 overflow-x-auto snap-x snap-mandatory scrollbar-hide pb-4">
                {%- for product in collection.products limit: products_to_show -%}
                  <div class="snap-start shrink-0 w-[70vw] min-[480px]:w-[45vw]">
                    {%- render 'product-grid-item',
                      product: product,
                      show_vendor: show_vendor,
                      show_quick_add: show_quick_add,
                      image_ratio: image_ratio
                    -%}
                  </div>
                {%- endfor -%}
              </div>
            </div>

            {%- if show_view_all -%}
              <div class="mt-8 md:mt-10 {% if heading_alignment == 'center' %}text-center{% endif %}">
                <a
                  href="{{ collection.url }}"
                  class="inline-flex items-center gap-2 text-sm font-semibold text-cloud-burst-500 transition-colors hover:text-cloud-burst-300"
                >
                  View all {{ collection.title }}
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                  </svg>
                </a>
              </div>
            {%- endif -%}
          {%- else -%}
            <div class="rounded-lg border-2 border-dashed border-gray-300 py-16 text-center">
              <p class="text-sm text-gray-500">
                {%- if collection == blank -%}
                  Select a collection for this tab
                {%- else -%}
                  This collection has no products yet
                {%- endif -%}
              </p>
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
{%- else -%}
  <div class="px-6 md:px-8 py-12">
    <div class="container">
      <div class="rounded-lg border-2 border-dashed border-gray-300 py-16 text-center">
        <p class="text-sm text-gray-500">Add collection tabs to get started</p>
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Tabbed Collections",
  "tag": "section",
  "class": "section-tabbed-collections",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Large" },
        { "value": "h3", "label": "Medium" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Product grid"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Maximum products to show",
      "min": 4,
      "max": 24,
      "step": 2,
      "default": 8
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "portrait", "label": "Portrait (3:4)" },
        { "value": "square", "label": "Square (1:1)" },
        { "value": "adapt", "label": "Adapt to image" }
      ],
      "default": "portrait"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show product vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_quick_add",
      "label": "Show quick add button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View all' link",
      "default": true
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "collection_tab",
      "name": "Collection Tab",
      "limit": 8,
      "settings": [
        {
          "type": "text",
          "id": "tab_label",
          "label": "Tab label",
          "info": "Leave blank to use collection title"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tabbed Collections",
      "blocks": [
        { "type": "collection_tab" },
        { "type": "collection_tab" },
        { "type": "collection_tab" }
      ]
    }
  ]
}
{% endschema %}
