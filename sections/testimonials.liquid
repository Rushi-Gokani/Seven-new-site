{% schema %}
{
  "name": "Testimonials",
  "class": "section-testimonials",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Customers Say"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Real reviews from real customers"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns per row",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" }
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "background",
      "label": "Background style",
      "options": [
        { "value": "none", "label": "None (white)" },
        { "value": "light", "label": "Light gray" },
        { "value": "dark", "label": "Dark (cloud-burst)" }
      ],
      "default": "light"
    },
    {
      "type": "checkbox",
      "id": "show_stars",
      "label": "Show star ratings",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author_image",
      "label": "Show author images",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Star rating",
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Testimonial text",
          "default": "Absolutely love the quality of these products! The attention to detail is incredible and shipping was fast."
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author name",
          "default": "Sarah Johnson"
        },
        {
          "type": "text",
          "id": "author_title",
          "label": "Author title/company",
          "default": "Verified Buyer"
        },
        {
          "type": "image_picker",
          "id": "author_image",
          "label": "Author photo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "Absolutely love the quality of these products! The attention to detail is incredible and shipping was fast.",
            "author_name": "Sarah Johnson",
            "author_title": "Verified Buyer"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "Best online shopping experience I've had. Customer service was helpful and the products exceeded my expectations.",
            "author_name": "Michael Chen",
            "author_title": "Repeat Customer"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "Beautiful craftsmanship and sustainable materials. Exactly what I was looking for. Will definitely order again!",
            "author_name": "Emily Davis",
            "author_title": "Interior Designer"
          }
        }
      ]
    }
  ]
}
{% endschema %}

{%- liquid
  assign bg_class = ''
  assign text_class = ''
  assign card_bg = 'bg-white'
  assign card_border = 'border border-gray-100'
  
  if section.settings.background == 'light'
    assign bg_class = 'bg-gray-50'
  elsif section.settings.background == 'dark'
    assign bg_class = 'bg-cloud-burst-600'
    assign text_class = 'text-white'
    assign card_bg = 'bg-cloud-burst-500'
    assign card_border = 'border border-cloud-burst-400'
  endif
  
  case section.settings.columns
    when '1'
      assign grid_class = 'md:grid-cols-1 max-w-2xl mx-auto'
    when '2'
      assign grid_class = 'md:grid-cols-2 max-w-4xl mx-auto'
    when '3'
      assign grid_class = 'md:grid-cols-3'
  endcase
-%}

<section class="testimonials px-6 py-16 md:px-8 md:py-24 {{ bg_class }}" aria-labelledby="testimonials-heading">
  <div class="container">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="mb-12 text-center {{ text_class }}">
        {%- if section.settings.heading != blank -%}
          <h2 id="testimonials-heading" class="mb-3 text-3xl font-bold md:text-4xl">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="text-gray-500 md:text-lg{% if section.settings.background == 'dark' %} !text-gray-300{% endif %}">
            {{ section.settings.subheading }}
          </p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      {%- assign total_slides = section.blocks.size -%}
      
      <div 
        class="testimonials-carousel relative md:block {% if section.blocks.size <= 3 %}{{ grid_class }}{% endif %}"
        x-data="testimonialCarousel({{ total_slides }})"
        x-init="init()"
        @touchstart="onTouchStart($event)"
        @touchend="onTouchEnd($event)"
      >
        <div class="overflow-hidden md:contents">
          <div 
            class="testimonial-track flex transition-transform duration-300 ease-out md:block md:transform-none"
            data-carousel-track
          >
            {%- for block in section.blocks -%}
              <div class="testimonial-slide w-full flex-shrink-0 px-1 md:w-auto md:flex-none md:px-0">
                <article 
                  class="testimonial-card rounded-2xl p-6 md:p-8 {{ card_bg }} {{ card_border }} transition-shadow hover:shadow-lg"
                  {{ block.shopify_attributes }}
                >
                  {%- if section.settings.show_stars -%}
                    <div class="mb-4 flex gap-1" aria-label="{{ block.settings.rating }} out of 5 stars">
                      {%- for i in (1..5) -%}
                        {%- if i <= block.settings.rating -%}
                          <svg class="h-5 w-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                          </svg>
                        {%- else -%}
                          <svg class="h-5 w-5 text-gray-300" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                          </svg>
                        {%- endif -%}
                      {%- endfor -%}
                    </div>
                  {%- endif -%}

                  {%- if block.settings.quote != blank -%}
                    <blockquote class="mb-6 text-gray-700 leading-relaxed{% if section.settings.background == 'dark' %} !text-gray-200{% endif %}">
                      <p class="relative">
                        <span class="absolute -top-2 -left-1 text-3xl text-cloud-burst-200{% if section.settings.background == 'dark' %} !text-cloud-burst-400{% endif %}">"</span>
                        <span class="pl-4">{{ block.settings.quote }}</span>
                      </p>
                    </blockquote>
                  {%- endif -%}

                  <footer class="flex items-center gap-4">
                    {%- if section.settings.show_author_image -%}
                      <div class="author-image flex-shrink-0">
                        {%- if block.settings.author_image != blank -%}
                          <img
                            src="{{ block.settings.author_image | image_url: width: 80, height: 80, crop: 'center' }}"
                            srcset="{{ block.settings.author_image | image_url: width: 48, height: 48, crop: 'center' }} 1x,
                                    {{ block.settings.author_image | image_url: width: 96, height: 96, crop: 'center' }} 2x"
                            alt="{{ block.settings.author_name | escape }}"
                            class="h-12 w-12 rounded-full object-cover ring-2 ring-white"
                            loading="lazy"
                            decoding="async"
                            width="48"
                            height="48"
                          >
                        {%- else -%}
                          <div class="flex h-12 w-12 items-center justify-center rounded-full bg-cloud-burst text-sm font-semibold text-white">
                            {{- block.settings.author_name | slice: 0 | upcase -}}
                          </div>
                        {%- endif -%}
                      </div>
                    {%- endif -%}

                    <div class="author-info min-w-0">
                      {%- if block.settings.author_name != blank -%}
                        <cite class="not-italic font-semibold text-cloud-burst-800{% if section.settings.background == 'dark' %} !text-white{% endif %}">
                          {{ block.settings.author_name }}
                        </cite>
                      {%- endif -%}
                      {%- if block.settings.author_title != blank -%}
                        <p class="text-sm text-gray-500 truncate{% if section.settings.background == 'dark' %} !text-gray-400{% endif %}">
                          {{ block.settings.author_title }}
                        </p>
                      {%- endif -%}
                    </div>
                  </footer>
                </article>
              </div>
            {%- endfor -%}
          </div>
        </div>

        <div class="mt-8 flex items-center justify-center gap-2 md:hidden">
          {%- for i in (0..total_slides) -%}
            {%- if forloop.index0 < total_slides -%}
              <button 
                class="h-3 w-3 rounded-full transition-colors {% if forloop.index0 == 0 %}bg-cloud-burst-600{% else %}bg-gray-300{% endif %}"
                :class="{ 'bg-cloud-burst-600': activeIndex === {{ forloop.index0 }}, 'bg-gray-300': activeIndex !== {{ forloop.index0 }} }"
                @click="goTo({{ forloop.index0 }})"
                aria-label="Go to slide {{ forloop.index0 | plus: 1 }}"
              ></button>
            {%- endif -%}
          {%- endfor -%}
        </div>

        <button 
          class="absolute left-0 top-1/2 z-10 -translate-y-1/2 -translate-x-2 rounded-full bg-white p-3 shadow-lg transition-transform hover:scale-110 md:hidden"
          @click="prev()"
          aria-label="Previous testimonial"
        >
          <svg class="h-5 w-5 text-cloud-burst-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
        </button>

        <button 
          class="absolute right-0 top-1/2 z-10 -translate-y-1/2 translate-x-2 rounded-full bg-white p-3 shadow-lg transition-transform hover:scale-110 md:hidden"
          @click="next()"
          aria-label="Next testimonial"
        >
          <svg class="h-5 w-5 text-cloud-burst-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </button>
      </div>
    {%- else -%}
      <div class="text-center py-12 text-gray-500">
        <p>Add testimonials by clicking "Add block" in the theme editor.</p>
      </div>
    {%- endif -%}
  </div>
</section>
